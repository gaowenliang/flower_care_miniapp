/* app.wxss — 全局样式 v2（按 design.md 规范） */

/* 色彩变量（小程序不支持CSS变量统一管理，但注释标注来源） */
/* 主色 #4CAF50  辅色 #66BB6A  背景 #F7F9F7  卡片 #FFFFFF */
/* 文字 #2D3436  次要 #90A4AE  警告 #FF7043  成功 #26A69A */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  background-color: #F7F9F7;
  color: #2D3436;
  font-size: 28rpx;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* 通用容器 */
.container {
  padding: 24rpx 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
  min-height: 100vh;
}

/* 卡片 — 圆角24rpx */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(76, 175, 80, 0.05);
}

/* 主按钮 — 圆角44rpx全圆 */
.btn-primary {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 22rpx 64rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 1rpx;
}
.btn-primary::after { border: none; }

/* 次按钮 */
.btn-secondary {
  background: #F7F9F7;
  color: #4CAF50;
  border: 2rpx solid #E8F5E9;
  border-radius: 44rpx;
  padding: 18rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}
.btn-secondary::after { border: none; }

/* 标签 — 圆角20rpx */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-water { background: #E3F2FD; color: #1976D2; }
.tag-sun   { background: #FFF8E1; color: #F57F17; }
.tag-fert  { background: #E8F5E9; color: #388E3C; }
.tag-warn  { background: #FFF3E0; color: #FF7043; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
  text-align: center;
}
.empty-state .emoji { font-size: 120rpx; margin-bottom: 28rpx; }
.empty-state .title { font-size: 32rpx; font-weight: 600; color: #2D3436; margin-bottom: 12rpx; }
.empty-state .desc  { font-size: 26rpx; color: #90A4AE; margin-bottom: 40rpx; line-height: 1.5; }

/* 分隔线 */
.divider { height: 1rpx; background: #F0F2F0; margin: 16rpx 0; }

/* 工具类 */
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-20 { margin-bottom: 20rpx; }

.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1 { flex: 1; }
