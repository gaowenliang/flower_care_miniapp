/* app.wxss — 全局样式 v2（按 design.md 规范） */

/* 色彩变量（小程序不支持CSS变量统一管理，但注释标注来源） */
/* 主色 #4CAF50  辅色 #66BB6A  背景 #F7F9F7  卡片 #FFFFFF */
/* 文字 #2D3436  次要 #90A4AE  警告 #5D4037  成功 #26A69A */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  background-color: #F7F9F7;
  color: #2D3436;
  font-size: 28rpx;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* 通用容器 */
.container {
  padding: 24rpx 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
  min-height: 100vh;
}

/* 卡片 — 圆角24rpx */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(76, 175, 80, 0.05);
}

/* 主按钮 — 圆角44rpx全圆 */
.btn-primary {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 22rpx 64rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 1rpx;
}
.btn-primary::after { border: none; }

/* 次按钮 */
.btn-secondary {
  background: #F7F9F7;
  color: #4CAF50;
  border: 2rpx solid #E8F5E9;
  border-radius: 44rpx;
  padding: 18rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}
.btn-secondary::after { border: none; }

/* 标签 — 圆角20rpx */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-water { background: #E3F2FD; color: #1976D2; }
.tag-sun   { background: #FFF8E1; color: #F57F17; }
.tag-fert  { background: #E8F5E9; color: #388E3C; }
.tag-warn  { background: #EFEBE9; color: #5D4037; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
  text-align: center;
}
.empty-state .emoji { font-size: 120rpx; margin-bottom: 28rpx; }
.empty-state .title { font-size: 32rpx; font-weight: 600; color: #2D3436; margin-bottom: 12rpx; }
.empty-state .desc  { font-size: 26rpx; color: #90A4AE; margin-bottom: 40rpx; line-height: 1.5; }

/* SVG风格空状态插画 */
.empty-illust {
  width: 200rpx; height: 200rpx; margin-bottom: 32rpx; position: relative;
}
.empty-illust .pot {
  position: absolute; bottom: 20rpx; left: 50%; transform: translateX(-50%);
  width: 80rpx; height: 60rpx; background: #A5D6A7; border-radius: 0 0 16rpx 16rpx;
}
.empty-illust .pot::before {
  content: ''; position: absolute; top: -10rpx; left: -8rpx; right: -8rpx;
  height: 14rpx; background: #81C784; border-radius: 8rpx;
}
.empty-illust .stem {
  position: absolute; bottom: 80rpx; left: 50%; transform: translateX(-50%);
  width: 6rpx; height: 60rpx; background: #66BB6A; border-radius: 3rpx;
}
.empty-illust .leaf {
  position: absolute; width: 40rpx; height: 24rpx; background: #81C784; border-radius: 50%;
}

/* 分隔线 */
.divider { height: 1rpx; background: #F0F2F0; margin: 16rpx 0; }

/* 工具类 */
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-20 { margin-bottom: 20rpx; }

.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1 { flex: 1; }

/* 页面过渡动画 */
page {
  animation: pageIn 0.25s ease-out;
}
@keyframes pageIn { from{opacity:0} to{opacity:1} }

/* 按钮通用反馈 */
view[class*="btn"]:active {
  transform: scale(0.96);
  transition: transform 0.1s;
}

/* ========== 公共组件样式（从各页面提取） ========== */

/* 模态框 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 86%;
  max-width: 620rpx;
  overflow: hidden;
  animation: modalIn 0.2s ease-out;
}
@keyframes modalIn { from { opacity:0; transform: scale(0.92) } to { opacity:1; transform: scale(1) } }
.modal-header { padding: 36rpx 30rpx 12rpx; text-align: center; }
.modal-title { font-size: 32rpx; font-weight: 600; color: #2D3436; }
.modal-footer { display: flex; border-top: 1rpx solid #F0F2F0; }
.modal-footer view { flex: 1; text-align: center; padding: 30rpx; font-size: 30rpx; }
.modal-btn.confirm { background: #4CAF50; color: #fff; }
.modal-btn.cancel { background: #f5f5f5; color: #666; }
.btn-cancel { color: #90A4AE; }

/* 表单 */
.form-item { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; color: #90A4AE; margin-bottom: 12rpx; display: block; }
.form-input {
  border: 2rpx solid #E8F5E9;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  background: #F7F9F7;
}

/* 分区标题 */
.section-title {
  font-size: 30rpx; font-weight: 600; color: #2D3436;
  margin-bottom: 16rpx; display: flex; align-items: center; gap: 8rpx;
}

/* 搜索输入 */
.search-input {
  flex: 1; font-size: 28rpx; color: #2D3436; height: 56rpx;
  line-height: 56rpx;
}

/* 步骤条 */
.step { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.step.active .step-num { background: #4CAF50; color: #fff; }
.step.active .step-label { color: #4CAF50; font-weight: 600; }
.step-label { font-size: 22rpx; color: #B0BEC5; }

/* 内容淡入 */
.content-fade { animation: fadeIn 0.3s ease-out; }
@keyframes fadeIn { from{opacity:0;transform:translateY(16rpx)} to{opacity:1;transform:translateY(0)} }

/* 加载动画 */
@keyframes spin { to { transform: rotate(360deg); } }
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
