/* pages/identify/identify.wxss */

.container { padding: 24rpx; }

/* 拍照区 */
.photo-preview {
  background: #F7F9F7; border-radius: 20rpx; overflow: hidden;
  margin-bottom: 24rpx; text-align: center;
}
.preview-img { width: 100%; max-height: 360rpx; }

.camera-bar { display: flex; gap: 16rpx; margin: 40rpx 0; }
.btn-camera {
  flex: 1; text-align: center; padding: 24rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white; border-radius: 44rpx; font-size: 28rpx; font-weight: 600;
}
.btn-album { background: linear-gradient(135deg, #66BB6A, #81C784); }

/* 标题 */
.section-title {
  font-size: 30rpx; font-weight: 600; color: #2D3436;
  margin-bottom: 16rpx;
}
.result-hint { font-size: 24rpx; color: #90A4AE; font-weight: 400; }

/* 结果列表 */
.result-list { display: flex; flex-direction: column; gap: 12rpx; }

.result-row {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border-radius: 16rpx; padding: 16rpx 20rpx;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  transition: background 0.15s;
}
.result-row:active { background: #F1F8E9; }
.result-row.matched { border-left: 6rpx solid #4CAF50; }

/* 缩略图 */
.result-thumb {
  width: 80rpx; height: 80rpx; border-radius: 12rpx;
  flex-shrink: 0; background: #E8F5E9;
}
.result-thumb-placeholder {
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
}

/* 中间信息 */
.result-info { flex: 1; min-width: 0; overflow: hidden; }
.result-top { display: flex; align-items: center; gap: 8rpx; }
.result-name { font-size: 30rpx; font-weight: 600; color: #2D3436; }
.result-score {
  font-size: 22rpx; color: #4CAF50; font-weight: 600;
  background: #E8F5E9; padding: 2rpx 12rpx; border-radius: 20rpx;
  flex-shrink: 0;
}
.result-desc {
  font-size: 24rpx; color: #90A4AE; line-height: 1.4;
  margin-top: 4rpx;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden; text-overflow: ellipsis;
}
.result-match { margin-top: 6rpx; }
.match-tag { font-size: 22rpx; color: #4CAF50; font-weight: 500; }
.no-match { font-size: 22rpx; color: #B0BEC5; margin-top: 4rpx; display: block; }

/* 右箭头 */
.result-arrow {
  font-size: 32rpx; color: #B0BEC5; flex-shrink: 0;
  padding-left: 8rpx;
}

/* 错误 */
.error-card { text-align: center; padding: 40rpx; }
.error-text { font-size: 28rpx; color: #90A4AE; display: block; margin-bottom: 24rpx; }
.error-btns { display: flex; justify-content: center; gap: 16rpx; }
.btn-retry {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white; padding: 16rpx 40rpx; border-radius: 44rpx;
  font-size: 28rpx; font-weight: 600;
}
.btn-manual {
  background: #F7F9F7; color: #90A4AE; padding: 16rpx 40rpx;
  border-radius: 44rpx; font-size: 28rpx;
}

/* 加载 */
.loading { text-align: center; padding: 100rpx 0; }
.loading-spinner {
  width: 60rpx; height: 60rpx; border: 6rpx solid #E8F5E9;
  border-top: 6rpx solid #4CAF50; border-radius: 50%;
  margin: 0 auto 20rpx; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #90A4AE; }
