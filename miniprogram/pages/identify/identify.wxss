/* pages/identify/identify.wxss */
.photo-preview {
  background: #F7F9F7; border-radius: 20rpx; overflow: hidden;
  margin-bottom: 24rpx; text-align: center;
}
.preview-img { width: 100%; max-height: 400rpx; }

.section-title {
  font-size: 32rpx; font-weight: 600; color: #2D3436;
  margin-bottom: 20rpx; padding: 8rpx;
}

.result-card { padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.result-name { font-size: 32rpx; font-weight: 600; color: #2D3436; }
.result-score {
  font-size: 26rpx; color: #4CAF50; font-weight: 600;
  background: #E8F5E9; padding: 4rpx 16rpx; border-radius: 20rpx;
}
.result-desc { font-size: 26rpx; color: #607D8B; line-height: 1.6; margin-bottom: 16rpx; }
.result-match { background: #F1F8E9; border-radius: 16rpx; padding: 16rpx; margin-bottom: 16rpx; }
.match-tag { font-size: 24rpx; color: #4CAF50; font-weight: 600; }
.match-care { margin-top: 8rpx; font-size: 24rpx; color: #607D8B; }
.result-actions { display: flex; gap: 16rpx; }
.btn-add {
  flex: 1; text-align: center; padding: 16rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white; border-radius: 44rpx; font-size: 28rpx; font-weight: 600;
}
.btn-add.disabled { background: #E0E0E0; color: #9E9E9E; }

.error-card { text-align: center; padding: 40rpx; }
.error-text { font-size: 28rpx; color: #90A4AE; display: block; margin-bottom: 24rpx; }
.btn-retry {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white; padding: 16rpx 40rpx; border-radius: 44rpx;
  font-size: 28rpx; font-weight: 600; display: inline-block; margin: 0 8rpx;
}
.btn-manual {
  background: #F7F9F7; color: #90A4AE; padding: 16rpx 40rpx;
  border-radius: 44rpx; font-size: 28rpx; display: inline-block; margin: 0 8rpx;
}

.loading { text-align: center; padding: 100rpx 0; }
.loading-spinner {
  width: 60rpx; height: 60rpx; border: 6rpx solid #E8F5E9;
  border-top: 6rpx solid #4CAF50; border-radius: 50%;
  margin: 0 auto 20rpx; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #90A4AE; }
