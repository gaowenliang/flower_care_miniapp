/* pages/family/family.wxss */
.loading-state {
  display: flex; justify-content: center; align-items: center;
  padding: 120rpx 0;
  color: #B0BEC5;
}

.empty-hero {
  padding: 80rpx 40rpx; text-align: center;
}
.hero-emoji { font-size: 100rpx; display: block; margin-bottom: 24rpx; }
.hero-title { font-size: 40rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 12rpx; }
.hero-desc { font-size: 28rpx; color: #90A4AE; display: block; line-height: 1.6; }

.action-card {
  display: flex; align-items: center; padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
}
.action-icon-wrap {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx; flex-shrink: 0;
}
.action-icon-wrap.create { background: linear-gradient(135deg, #E8F5E9, #C8E6C9); }
.action-icon-wrap.join { background: linear-gradient(135deg, #E3F2FD, #BBDEFB); }
.action-icon { font-size: 40rpx; }
.action-info { flex: 1; }
.action-title { font-size: 32rpx; font-weight: 500; color: #2D3436; display: block; margin-bottom: 8rpx; }
.action-desc { font-size: 24rpx; color: #90A4AE; }
.action-arrow { font-size: 40rpx; color: #B0BEC5; }

.tips-card { padding: 28rpx; }
.tips-title { font-size: 28rpx; font-weight: 600; color: #4CAF50; display: block; margin-bottom: 16rpx; }
.tips-text { font-size: 24rpx; color: #78909C; display: block; margin-bottom: 8rpx; line-height: 1.6; }

/* 家庭头部 */
.family-header { padding: 32rpx 28rpx; }
.fh-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28rpx; }
.fh-info { display: flex; align-items: center; }
.fh-emoji { font-size: 48rpx; margin-right: 16rpx; }
.fh-text { display: flex; flex-direction: column; }
.fh-name { font-size: 36rpx; font-weight: 600; color: #2D3436; margin-bottom: 6rpx; }
.fh-role { font-size: 24rpx; color: #90A4AE; }
.fh-edit { font-size: 32rpx; padding: 12rpx; color: #90A4AE; }

.invite-section { background: #F7F9F7; border-radius: 16rpx; padding: 20rpx; }
.invite-label { font-size: 24rpx; color: #78909C; display: block; margin-bottom: 12rpx; }
.invite-code-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.invite-code {
  font-size: 36rpx; font-weight: 700; color: #4CAF50;
  letter-spacing: 6rpx; font-family: monospace;
  background: #FFF; padding: 12rpx 20rpx; border-radius: 12rpx;
}
.invite-btn {
  background: #E8F5E9; color: #4CAF50; padding: 10rpx 16rpx;
  border-radius: 24rpx; font-size: 22rpx; font-weight: 500;
}
.invite-hint { font-size: 22rpx; color: #B0BEC5; }

/* 成员列表 */
.member-item {
  display: flex; align-items: center; padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F2F0;
}
.member-item:last-child { border-bottom: none; }
.member-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #F7F9F7; display: flex; align-items: center;
  justify-content: center; font-size: 28rpx; margin-right: 20rpx;
}
.member-info { flex: 1; }
.member-name { font-size: 28rpx; font-weight: 500; color: #2D3436; display: block; margin-bottom: 4rpx; }
.member-role { font-size: 22rpx; color: #90A4AE; }
.member-kick {
  padding: 10rpx 20rpx; background: #FFEBEE; color: #D32F2F;
  border-radius: 24rpx; font-size: 24rpx; font-weight: 500;
}

/* 操作区 */
.action-area { padding: 28rpx; }
.danger-btn {
  background: #FFEBEE; color: #D32F2F; padding: 24rpx;
  border-radius: 16rpx; text-align: center; font-size: 28rpx; font-weight: 600;
}

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45); display: flex;
  align-items: center; justify-content: center; z-index: 999;
}
.modal-content {
  width: 80%; background: #FFF; border-radius: 28rpx; overflow: hidden;
}
.modal-header { padding: 36rpx 30rpx 16rpx; text-align: center; }
.modal-title { font-size: 32rpx; font-weight: 600; color: #2D3436; }
.modal-body { padding: 16rpx 40rpx 28rpx; }
.modal-footer {
  display: flex; border-top: 1rpx solid #F0F2F0;
}
.modal-footer view {
  flex: 1; text-align: center; padding: 30rpx; font-size: 30rpx;
}

/* 表单 */
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #607D8B; display: block; margin-bottom: 12rpx; }
.form-input {
  border: 2rpx solid #E8F5E9; border-radius: 20rpx;
  padding: 20rpx; font-size: 28rpx; background: #F7F9F7; color: #2D3436;
}
.invite-input { font-family: monospace; font-size: 40rpx; letter-spacing: 8rpx; text-align: center; font-weight: 600; }
.form-hint { font-size: 22rpx; color: #B0BEC5; display: block; margin-top: 8rpx; }

.btn-cancel { color: #90A4AE; }
.btn-primary {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white; font-weight: 600;
}