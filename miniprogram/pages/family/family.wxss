/* pages/family/family.wxss v2 */
.page-family { min-height: 100vh; background: #F7F9F7; padding-bottom: 40rpx; }

/* 加载 */
.loading-box { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 4rpx solid #e0e0e0; border-top-color: #4CAF50; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 20rpx; color: #999; font-size: 28rpx; }

/* 未加入家庭 */
.no-family { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 30rpx; }
.empty-title { font-size: 40rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.empty-desc { font-size: 28rpx; color: #888; margin-bottom: 60rpx; }
.action-cards { width: 100%; }
.action-card { background: #fff; border-radius: 24rpx; padding: 40rpx; margin-bottom: 30rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06); }
.action-card:active { transform: scale(0.98); }
.card-icon { font-size: 56rpx; margin-bottom: 16rpx; }
.card-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.card-desc { font-size: 26rpx; color: #888; }

/* 家庭信息 */
.family-info { padding: 20rpx 30rpx; }
.family-header { background: linear-gradient(135deg, #4CAF50, #66BB6A); border-radius: 24rpx; padding: 40rpx; margin-bottom: 24rpx; }
.family-name { font-size: 40rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.family-meta { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.member-count { font-size: 26rpx; color: rgba(255,255,255,0.85); }
.role-tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; color: #fff; }
.role-tag.admin { background: rgba(255,255,255,0.3); }
.role-tag.member { background: rgba(255,255,255,0.2); }
.points-badge { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 20rpx; background: rgba(255,255,255,0.25); color: #fff; }

/* 邀请码 */
.invite-section { margin-bottom: 24rpx; }
.invite-card { background: #fff; border-radius: 20rpx; padding: 30rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.invite-label { font-size: 26rpx; color: #888; margin-bottom: 16rpx; }
.invite-code { font-size: 56rpx; font-weight: bold; letter-spacing: 16rpx; color: #4CAF50; margin-bottom: 24rpx; font-family: monospace; }
.invite-actions { display: flex; gap: 20rpx; }
.invite-btn { font-size: 26rpx; padding: 12rpx 32rpx; border-radius: 32rpx; border: none; }
.invite-btn.copy { background: #E8F5E9; color: #4CAF50; }
.invite-btn.share { background: #4CAF50; color: #fff; }
.invite-btn.share::after { border: none; }

/* Tab */
.tab-bar { display: flex; background: #fff; border-radius: 16rpx; margin-bottom: 24rpx; padding: 8rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx; font-size: 28rpx; color: #888; border-radius: 12rpx; }
.tab.active { background: #4CAF50; color: #fff; font-weight: bold; }

/* 时间段 */
.period-bar { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.period-btn { flex: 1; text-align: center; padding: 16rpx; font-size: 26rpx; color: #888; background: #fff; border-radius: 12rpx; }
.period-btn.active { background: #E8F5E9; color: #4CAF50; font-weight: bold; }

/* Section Card */
.section-card { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; }

/* 积分排行 */
.leaderboard {}
.lb-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.lb-item:last-child { border-bottom: none; }
.lb-item.first { background: #FFF8E1; margin: 0 -30rpx; padding: 20rpx 30rpx; border-radius: 12rpx; border-bottom: none; }
.lb-rank { width: 48rpx; font-size: 28rpx; font-weight: bold; color: #aaa; text-align: center; }
.lb-item.first .lb-rank { color: #FF9800; font-size: 32rpx; }
.lb-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24rpx; font-weight: bold; margin: 0 16rpx; flex-shrink: 0; }
.lb-info { flex: 1; }
.lb-name { font-size: 28rpx; color: #333; font-weight: 500; }
.lb-detail { font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
.lb-points { font-size: 28rpx; font-weight: bold; color: #FF9800; }

/* 统计总览 */
.stat-overview { display: flex; justify-content: space-around; padding: 16rpx 0; }
.stat-item { text-align: center; }
.stat-num { font-size: 44rpx; font-weight: bold; color: #4CAF50; }
.stat-label { font-size: 24rpx; color: #888; margin-top: 4rpx; }

/* 柱状图 */
.bar-chart { display: flex; align-items: flex-end; gap: 16rpx; padding: 20rpx 0; min-height: 300rpx; }
.bar-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.bar-name { font-size: 22rpx; color: #666; max-width: 100rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bar-track { width: 100%; display: flex; justify-content: center; }
.bar-fill { width: 48rpx; background: linear-gradient(180deg, #66BB6A, #4CAF50); border-radius: 8rpx 8rpx 0 0; min-height: 8rpx; }
.bar-val { font-size: 20rpx; color: #999; }

/* 养护类型 */
.type-list {}
.type-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.type-item:last-child { border-bottom: none; }
.type-emoji { font-size: 32rpx; margin-right: 16rpx; width: 48rpx; text-align: center; }
.type-name { flex: 1; font-size: 28rpx; color: #333; }
.type-count { font-size: 28rpx; color: #4CAF50; font-weight: 600; }

/* 成员列表 */
.member-list {}
.member-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 28rpx; font-weight: bold; margin-right: 20rpx; flex-shrink: 0; }
.member-info { flex: 1; }
.member-name { font-size: 28rpx; color: #333; }
.member-role { font-size: 24rpx; color: #aaa; margin-top: 4rpx; }
.kick-btn { font-size: 24rpx; color: #e53935; padding: 8rpx 20rpx; }
.edit-nickname { text-align: center; font-size: 26rpx; color: #4CAF50; padding: 20rpx 0; border-top: 1rpx solid #f0f0f0; margin-top: 16rpx; }

/* 底部 */
.bottom-actions { margin-top: 40rpx; }
.action-btn { text-align: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.action-btn.leave, .action-btn.dissolve { background: #fff; color: #e53935; border: 2rpx solid #ffcdd2; }
.empty-hint { text-align: center; font-size: 26rpx; color: #ccc; padding: 30rpx 0; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 999; }
.modal-content { background: #fff; border-radius: 24rpx; padding: 50rpx 40rpx; width: 600rpx; }
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 40rpx; }
.modal-field { margin-bottom: 40rpx; }
.modal-input { border: 2rpx solid #e0e0e0; border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 30rpx; width: 100%; box-sizing: border-box; }
.invite-input { letter-spacing: 12rpx; text-align: center; font-size: 40rpx; font-weight: bold; text-transform: uppercase; }
.modal-btns { display: flex; gap: 20rpx; }
.modal-btn { flex: 1; text-align: center; padding: 20rpx; border-radius: 16rpx; font-size: 30rpx; }
.modal-btn.cancel { background: #f5f5f5; color: #666; }
.modal-btn.confirm { background: #4CAF50; color: #fff; }
