/* pages/family/family.wxss v3 */
.page-family { min-height: 100vh; background: #F7F9F7; padding-bottom: 40rpx; }
.loading-box { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 4rpx solid #e0e0e0; border-top-color: #4CAF50; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 20rpx; color: #999; font-size: 28rpx; }

/* 未加入 */
.no-family { display: flex; flex-direction: column; align-items: center; padding: 60rpx 40rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #888; margin-bottom: 48rpx; }
.action-cards { width: 100%; }
.action-card { background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.action-card:active { transform: scale(0.98); }
.card-icon { font-size: 44rpx; margin-bottom: 12rpx; }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 4rpx; }
.card-desc { font-size: 24rpx; color: #888; }

/* 头部 */
.family-info { padding: 16rpx 24rpx; }
.family-header { background: linear-gradient(135deg, #4CAF50, #66BB6A); border-radius: 20rpx; padding: 28rpx; margin-bottom: 16rpx; }
.family-name { font-size: 36rpx; font-weight: bold; color: #fff; margin-bottom: 8rpx; }
.family-meta { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.member-count { font-size: 24rpx; color: rgba(255,255,255,0.85); }
.role-tag { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 16rpx; color: #fff; }
.role-tag.admin { background: rgba(255,255,255,0.3); }
.role-tag.member { background: rgba(255,255,255,0.2); }
.points-badge { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 16rpx; background: rgba(255,255,255,0.25); color: #fff; }

/* 邀请码 */
.invite-section { margin-bottom: 16rpx; }
.invite-card { background: #fff; border-radius: 16rpx; padding: 20rpx; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.invite-label { font-size: 22rpx; color: #999; margin-bottom: 8rpx; }
.invite-code { font-size: 44rpx; font-weight: 800; letter-spacing: 10rpx; color: #4CAF50; font-family: monospace; margin-bottom: 12rpx; }
.invite-actions { display: flex; gap: 16rpx; justify-content: center; }
.invite-btn { font-size: 24rpx; padding: 8rpx 24rpx; border-radius: 24rpx; border: none; }
.invite-btn.copy { background: #E8F5E9; color: #4CAF50; }
.invite-btn.share { background: #4CAF50; color: #fff; }
.invite-btn.share::after { border: none; }

/* Tab */
.tab-bar { display: flex; background: #fff; border-radius: 14rpx; margin-bottom: 16rpx; padding: 4rpx; }
.tab { flex: 1; text-align: center; padding: 12rpx; font-size: 26rpx; color: #888; border-radius: 10rpx; }
.tab.active { background: #4CAF50; color: #fff; font-weight: bold; }

/* 时间段 */
.period-bar { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.period-btn { flex: 1; text-align: center; padding: 12rpx; font-size: 24rpx; color: #888; background: #fff; border-radius: 10rpx; }
.period-btn.active { background: #E8F5E9; color: #4CAF50; font-weight: bold; }

/* Section */
.section-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.add-link { float: right; font-size: 24rpx; color: #4CAF50; font-weight: normal; }
.empty-hint { text-align: center; font-size: 24rpx; color: #ccc; padding: 20rpx 0; }

/* ===== 动态流 ===== */
.activity-list {}
.activity-item { display: flex; padding: 14rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.activity-item:last-child { border-bottom: none; }
.activity-emoji { font-size: 28rpx; margin-right: 12rpx; flex-shrink: 0; }
.activity-content { flex: 1; }
.activity-text { font-size: 26rpx; color: #333; line-height: 1.5; }
.activity-name { font-weight: 600; color: #4CAF50; }
.activity-time { font-size: 20rpx; color: #bbb; display: block; margin-top: 4rpx; }

/* ===== 排行 ===== */
.lb-item { display: flex; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.lb-item:last-child { border-bottom: none; }
.lb-item.first { background: #FFF8E1; margin: 0 -24rpx; padding: 14rpx 24rpx; border-radius: 10rpx; border: none; }
.lb-rank { width: 36rpx; font-size: 24rpx; font-weight: bold; color: #aaa; text-align: center; }
.lb-item.first .lb-rank { color: #FF9800; font-size: 28rpx; }
.lb-avatar { width: 52rpx; height: 52rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 22rpx; font-weight: bold; margin: 0 12rpx; flex-shrink: 0; }
.lb-info { flex: 1; }
.lb-name { font-size: 26rpx; color: #333; font-weight: 500; }
.lb-detail { font-size: 20rpx; color: #aaa; margin-top: 2rpx; }
.lb-points { font-size: 26rpx; font-weight: bold; color: #FF9800; }

/* 成员列表 */
.member-list {}
.member-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24rpx; font-weight: bold; margin-right: 16rpx; flex-shrink: 0; }
.member-info { flex: 1; }
.member-name { font-size: 26rpx; color: #333; }
.member-role { font-size: 22rpx; color: #aaa; margin-top: 2rpx; }
.kick-btn { font-size: 22rpx; color: #e53935; padding: 6rpx 16rpx; }
.edit-nickname { text-align: center; font-size: 24rpx; color: #4CAF50; padding: 16rpx 0; border-top: 1rpx solid #f0f0f0; margin-top: 12rpx; }

/* 统计 */
.stat-overview { display: flex; justify-content: space-around; padding: 12rpx 0; }
.stat-item { text-align: center; }
.stat-num { font-size: 36rpx; font-weight: bold; color: #4CAF50; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 柱状图 */
.bar-chart { display: flex; align-items: flex-end; gap: 12rpx; padding: 12rpx 0; min-height: 200rpx; }
.bar-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.bar-name { font-size: 20rpx; color: #666; max-width: 80rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bar-fill { width: 100%; max-width: 36rpx; background: linear-gradient(180deg, #66BB6A, #4CAF50); border-radius: 6rpx 6rpx 0 0; min-height: 6rpx; }
.bar-val { font-size: 18rpx; color: #999; }

/* 养护类型 */
.type-list {}
.type-item { display: flex; align-items: center; padding: 10rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.type-item:last-child { border-bottom: none; }
.type-emoji { font-size: 28rpx; margin-right: 12rpx; width: 36rpx; text-align: center; }
.type-name { flex: 1; font-size: 26rpx; color: #333; }
.type-count { font-size: 26rpx; color: #4CAF50; font-weight: 600; }

/* ===== 周报 ===== */
.weekly-report {}
.wr-item { font-size: 24rpx; color: #555; padding: 6rpx 0; line-height: 1.6; }

/* ===== PK ===== */
.pk-list {}
.pk-item { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.pk-item:last-child { border-bottom: none; }
.pk-emoji { font-size: 32rpx; margin-right: 14rpx; }
.pk-info { flex: 1; }
.pk-title { font-size: 26rpx; font-weight: bold; color: #333; }
.pk-desc { font-size: 22rpx; color: #888; margin-top: 2rpx; }

/* ===== 健康看板 ===== */
.health-list {}
.health-item { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.health-item:last-child { border-bottom: none; }
.health-plant-emoji { font-size: 28rpx; margin-right: 12rpx; }
.health-plant-info { flex: 1; }
.health-name { font-size: 26rpx; color: #333; font-weight: 500; }
.health-location { font-size: 20rpx; color: #aaa; margin-top: 2rpx; }
.health-score-wrap { display: flex; align-items: center; gap: 4rpx; }
.health-icon { font-size: 24rpx; }
.health-score { font-size: 26rpx; font-weight: bold; }
.health-score.excellent { color: #4CAF50; }
.health-score.good { color: #8BC34A; }
.health-score.fair { color: #FF9800; }
.health-score.poor { color: #e53935; }

/* ===== 心愿单 ===== */
.wish-list {}
.wish-item { padding: 14rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.wish-item:last-child { border-bottom: none; }
.wish-item.fulfilled { opacity: 0.6; }
.wish-content { display: flex; align-items: flex-start; }
.wish-emoji { font-size: 28rpx; margin-right: 12rpx; flex-shrink: 0; }
.wish-info { flex: 1; }
.wish-name { font-size: 26rpx; color: #333; font-weight: 500; }
.wish-note { font-size: 22rpx; color: #888; margin-top: 2rpx; }
.wish-meta { font-size: 20rpx; color: #bbb; margin-top: 4rpx; }
.wish-actions { display: flex; gap: 12rpx; margin-top: 8rpx; margin-left: 40rpx; }
.wish-btn { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 12rpx; }
.wish-btn.fulfill { background: #E8F5E9; color: #4CAF50; }
.wish-btn.remove { background: #fafafa; color: #999; }

/* ===== 里程碑 ===== */
.milestone-list {}
.milestone-item { display: flex; align-items: center; padding: 10rpx 0; }
.milestone-name { font-size: 26rpx; font-weight: bold; color: #FF9800; margin-right: 12rpx; }
.milestone-plant { font-size: 24rpx; color: #666; }

/* 底部 */
.bottom-actions { margin-top: 32rpx; }
.action-btn { text-align: center; padding: 20rpx; border-radius: 14rpx; font-size: 26rpx; background: #fff; color: #e53935; border: 2rpx solid #ffcdd2; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 999; }
.modal-content { background: #fff; border-radius: 20rpx; padding: 40rpx 32rpx; width: 560rpx; }
.modal-title { font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 32rpx; }
.modal-field { margin-bottom: 24rpx; }
.modal-input { border: 2rpx solid #e0e0e0; border-radius: 14rpx; padding: 16rpx 20rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }
.invite-input { letter-spacing: 10rpx; text-align: center; font-size: 36rpx; font-weight: bold; text-transform: uppercase; }
.modal-btns { display: flex; gap: 16rpx; }
.modal-btn { flex: 1; text-align: center; padding: 16rpx; border-radius: 14rpx; font-size: 28rpx; }
.modal-btn.cancel { background: #f5f5f5; color: #666; }
.modal-btn.confirm { background: #4CAF50; color: #fff; }
