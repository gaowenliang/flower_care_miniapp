/* pages/plant-journal/plant-journal.wxss */

/* 头部 — 单行布局 */
.journal-header {
  display: flex; align-items: center; gap: 12px;
}
.jh-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; flex-shrink: 0; overflow: hidden; position: relative;
}
.jh-avatar-img {
  width: 100%; height: 100%; position: absolute; top: 0; left: 0;
}
.jh-info {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column;
}
.jh-name { font-size: 16px; font-weight: 700; color: #2D3436; }
.jh-sub {
  font-size: 12px; color: #90A4AE; margin-top: 2px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.jh-actions { display: flex; gap: 8px; flex-shrink: 0; }
.jh-btn {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; background: #F7F9F7; color: #90A4AE;
}
.jh-btn.primary {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
  box-shadow: 0 4px 12px rgba(76,175,80,0.25);
}

/* 时间线 */
.timeline { margin-top: 12px; }
.timeline-group { margin-bottom: 20px; }

.date-header { margin-bottom: 10px; }
.date-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 4px 14px; background: #E8F5E9; border-radius: 20px;
}
.date-label { font-size: 14px; font-weight: 600; color: #4CAF50; }
.date-detail { font-size: 12px; color: #90A4AE; }

/* 照片网格 */
.photo-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px;
  padding-left: 8px;
}
.photo-item {
  position: relative; border-radius: 12px; overflow: hidden;
  aspect-ratio: 1; background: #F0F2F0;
}
.photo-img { width: 100%; height: 100%; display: block; }
.photo-time {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  padding: 16px 8px 6px; text-align: right;
}
.photo-time text { font-size: 10px; color: rgba(255,255,255,0.9); }

/* 备注列表 */
.note-list { padding: 8px 8px 0; }
.note-item {
  display: flex; padding: 10px 12px; background: #FFFFFF;
  border-radius: 12px; margin-bottom: 8px; align-items: flex-start;
}
.note-icon { font-size: 16px; margin-right: 10px; flex-shrink: 0; }
.note-content { flex: 1; }
.note-text { font-size: 14px; color: #2D3436; line-height: 1.5; display: block; }
.note-time { font-size: 11px; color: #B0BEC5; margin-top: 4px; display: block; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 60px 40px; text-align: center;
}
.empty-state .emoji { font-size: 80px; margin-bottom: 20px; }
.empty-state .title { font-size: 18px; font-weight: 600; color: #2D3436; margin-bottom: 8px; }
.empty-state .desc { font-size: 14px; color: #90A4AE; line-height: 1.6; white-space: pre-line; }

/* 图片预览 */
.preview-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.9); display: flex;
  align-items: center; justify-content: center; z-index: 999;
}
.preview-img { width: 100%; height: 100%; }
.preview-close {
  position: absolute; top: 50px; right: 20px;
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(255,255,255,0.2); color: white;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
}

/* 成长对比 */
.compare-section { margin-bottom: 16rpx; }
.compare-title { font-size: 30rpx; font-weight: 600; color: #2D3436; padding: 16rpx 8rpx; }
.compare-grid { display: flex; gap: 16rpx; }
.compare-item { flex: 1; text-align: center; }
.compare-img { width: 100%; height: 280rpx; border-radius: 16rpx; }
.compare-label { display: block; font-size: 24rpx; font-weight: 600; color: #2D3436; margin-top: 8rpx; }
.compare-date { display: block; font-size: 20rpx; color: #90A4AE; }


/* 照片删除按钮 */
.photo-item { position: relative; }
.photo-delete-btn {
  position: absolute; bottom: 16rpx; right: 16rpx;
  background: #e53935; color: #fff; font-size: 22rpx;
  padding: 6rpx 16rpx; border-radius: 8rpx;
  z-index: 10;
}

/* 备注删除按钮 */
.note-item { position: relative; align-items: center; }
.note-delete-btn {
  background: #e53935; color: #fff; font-size: 22rpx;
  padding: 6rpx 16rpx; border-radius: 8rpx;
  flex-shrink: 0; margin-left: 16rpx;
}

/* 照片操作浮层 */
.photo-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center; gap: 20rpx;
  z-index: 10;
}
.photo-action-btn {
  background: rgba(255,255,255,0.95); color: #333; font-size: 26rpx;
  padding: 16rpx 28rpx; border-radius: 12rpx; font-weight: 500;
}
.photo-item.menu-active .photo-img { border-radius: 16rpx; }

/* 备注删除按钮 */
.note-action-btn {
  background: #e53935; color: #fff; font-size: 22rpx;
  padding: 8rpx 20rpx; border-radius: 8rpx;
  flex-shrink: 0; margin-left: 16rpx;
}
.note-item.menu-active { background: #FFF8F0; }
