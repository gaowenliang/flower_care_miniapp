<!-- pages/plant-journal/plant-journal.wxml -->
<view class="container">
  <!-- 植物头部 -->
  <view class="journal-header card" wx:if="{{userPlant}}">
    <view class="jh-avatar">
      <image wx:if="{{userPlant.avatar}}" class="jh-avatar-img" src="{{userPlant.avatar}}" mode="aspectFill" />
      <text wx:else>{{userPlant.emoji}}</text>
    </view>
    <view class="jh-info">
      <text class="jh-name">{{userPlant.nickname}}</text>
      <text class="jh-sub">{{userPlant.name}} · 成长日记</text>
    </view>
    <view class="jh-actions">
      <view class="jh-btn primary" bindtap="takePhoto">📷</view>
      <view class="jh-btn" bindtap="addNote">📝</view>
    </view>
  </view>

  <!-- 成长对比 -->
  <view class="compare-section" wx:if="{{comparePhotos.length >= 2}}">
    <view class="compare-title">🔄 成长对比</view>
    <view class="compare-grid">
      <view class="compare-item" wx:for="{{comparePhotos}}" wx:key="label">
        <image class="compare-img" src="{{item.photo}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.photo}}" />
        <text class="compare-label">{{item.label}}</text>
        <text class="compare-date">{{item.date}}</text>
      </view>
    </view>
  </view>

  <!-- 时间线 -->
  <view class="timeline" wx:if="{{journal.length > 0}}">
    <view class="timeline-group" wx:for="{{journal}}" wx:key="date">
      <!-- 日期标题 -->
      <view class="date-header">
        <view class="date-badge">
          <text class="date-label">{{item.dateLabel}}</text>
          <text class="date-detail">{{item.date}} {{item.weekday}}</text>
        </view>
      </view>

      <!-- 照片网格 -->
      <view class="photo-grid" wx:if="{{item.photos.length > 0}}">
        <view class="photo-item {{photo.showMenu ? 'menu-active' : ''}}" wx:for="{{item.photos}}" wx:for-item="photo" wx:key="id"
              catchtap="toggleJournalMenu" data-id="{{photo.id}}">
          <image class="photo-img" src="{{photo.photo}}" lazy-load mode="aspectFill" />
          <view class="photo-overlay" wx:if="{{photo.showMenu}}">
            <view class="photo-action-btn" catchtap="deleteRecord" data-id="{{photo.id}}">🗑️ 删除</view>
            <view class="photo-action-btn" catchtap="previewImage" data-url="{{photo.photo}}">🔍 查看</view>
          </view>
          <view class="photo-time">
            <text>{{photo.time}}</text>
          </view>
        </view>
      </view>

      <!-- 当日备注 -->
      <view class="note-list" wx:if="{{item.notes.length > 0}}">
        <view class="note-item {{note.showMenu ? 'menu-active' : ''}}" wx:for="{{item.notes}}" wx:for-item="note" wx:key="id"
              catchtap="toggleJournalMenu" data-id="{{note.id}}">
          <text class="note-icon">📝</text>
          <view class="note-content">
            <text class="note-text">{{note.note}}</text>
            <text class="note-time">{{note.time}}</text>
          </view>
          <view class="note-action-btn" wx:if="{{note.showMenu}}" catchtap="deleteRecord" data-id="{{note.id}}">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{journal.length === 0}}">
    <text class="emoji">📷</text>
    <text class="title">还没有成长记录</text>
    <text class="desc">点击上方「📷 拍照」记录植物每天的状态\n它会成为珍贵的成长回忆~</text>
  </view>

  <!-- 图片预览 -->
  <view class="preview-mask" wx:if="{{showPreview}}" bindtap="closePreview">
    <image class="preview-img" src="{{previewImage}}" mode="aspectFit" />
    <view class="preview-close">✕</view>
  </view>
</view>
