/* pages/add-plant/add-plant.wxss — v2 */
.search-bar { display: flex; align-items: center; gap: 14rpx; margin-bottom: 16rpx; }
.search-input-wrap {
  flex: 1; display: flex; align-items: center;
  background: #FFFFFF; border-radius: 44rpx; padding: 16rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(76,175,80,0.06);
}
.search-icon { margin-right: 12rpx; font-size: 28rpx; }.search-input::placeholder { color: #90A4AE; }
.search-clear { color: #90A4AE; font-size: 28rpx; padding: 4rpx 12rpx; }

.camera-btn {
  width: 80rpx; height: 80rpx; background: #FFFFFF; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; box-shadow: 0 2rpx 16rpx rgba(76,175,80,0.06);
  transition: transform 0.15s;
}
.camera-btn:active { transform: scale(0.92); }

/* 分类 — 圆角44rpx全圆 */
.category-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.category-item {
  display: inline-flex; align-items: center;
  padding: 12rpx 28rpx; margin-right: 12rpx;
  border-radius: 44rpx; background: #FFFFFF;
  font-size: 26rpx; color: #90A4AE;
  transition: all 0.2s;
}
.category-item.active {
  background: linear-gradient(135deg, #4CAF50, #66BB6A); color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.25);
}
.cat-emoji { margin-right: 6rpx; }

/* 植物列表 */
.plant-list { display: flex; flex-direction: column; gap: 12rpx; }
.plant-item {
  display: flex; align-items: center;
  padding: 24rpx 28rpx !important;
  transition: transform 0.15s;
}
.plant-item:active { transform: scale(0.98); }

.plant-icon {
  width: 76rpx; height: 76rpx; border-radius: 20rpx;
  background: linear-gradient(135deg, #F7F9F7, #E8F5E9);
  display: flex; align-items: center; justify-content: center;
  font-size: 38rpx; margin-right: 24rpx; flex-shrink: 0;
}

.plant-desc { flex: 1; display: flex; flex-direction: column; }
.plant-name { font-size: 30rpx; font-weight: 600; color: #2D3436; }
.plant-latin { font-size: 22rpx; color: #B0BEC5; font-style: italic; margin-top: 2rpx; }
.plant-tags { display: flex; gap: 8rpx; margin-top: 10rpx; }

.plant-difficulty { display: flex; align-items: center; gap: 6rpx; flex-shrink: 0; }
.diff-dot { width: 12rpx; height: 12rpx; border-radius: 50%; }
.diff-text { font-size: 22rpx; color: #90A4AE; }

/* 弹窗 — 圆角28rpx */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); display: flex;
  align-items: flex-end; justify-content: center; z-index: 999;
  animation: fadeIn 0.2s ease;
}
.modal-content {
  width: 100%; max-height: 85vh; background: #FFFFFF; border-radius: 28rpx 28rpx 0 0;
  overflow: hidden; animation: slideUp 0.3s ease-out;
  display: flex; flex-direction: column;
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }.modal-emoji { font-size: 80rpx; display: block; margin-bottom: 12rpx; }
.modal-body { padding: 16rpx 24rpx 28rpx; overflow-y: auto; flex: 1; }.location-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.loc-opt {
  padding: 16rpx 28rpx; border-radius: 44rpx;
  background: #F7F9F7; font-size: 26rpx; color: #90A4AE;
  transition: all 0.2s; min-height: 64rpx;
  display: inline-flex; align-items: center;
}
.loc-opt.active { background: #E8F5E9; color: #4CAF50; font-weight: 600; }

.interval-control {
  display: flex; align-items: center; gap: 12rpx;
}
.interval-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #F7F9F7; display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #4CAF50; font-weight: 600;
}
.interval-btn:active { background: #E8F5E9; }
.interval-input {
  width: 80rpx; text-align: center; font-size: 32rpx; font-weight: 600; color: #2D3436;
  border: 2rpx solid #E8F5E9; border-radius: 16rpx; padding: 8rpx; height: 72rpx;
}
.interval-unit { font-size: 28rpx; color: #90A4AE; }
.form-hint { font-size: 22rpx; color: #B0BEC5; margin-top: 8rpx; display: block; }.btn-primary { color: #4CAF50; font-weight: 600; }

/* 自定义添加入口 */
.custom-add-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #4CAF50;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(76,175,80,0.3);
}

/* 识别结果 */
.identify-result-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F2F0;
}
.identify-result-item:active { background: #F7F9F7; }
.identify-result-item:last-child { border-bottom: none; }
.identify-emoji { font-size: 40rpx; margin-right: 16rpx; }
.identify-info { flex: 1; }
.identify-name { font-size: 30rpx; color: #2D3436; display: block; }
.identify-desc { font-size: 24rpx; color: #90A4AE; margin-top: 4rpx; display: block; }
.identify-score { font-size: 28rpx; font-weight: 600; }

/* emoji选择 */
.emoji-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.emoji-opt {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.emoji-opt.active {
  border-color: #4CAF50;
  background: #E8F5E9;
}
.picker-value { color: #2D3436; display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; }

/* 头像上传 */
.avatar-upload-row { display: flex; align-items: center; gap: 16rpx; }
.avatar-preview {
  position: relative; width: 160rpx; height: 160rpx; border-radius: 24rpx; overflow: hidden;
}
.avatar-preview-img { width: 100%; height: 100%; }
.avatar-remove {
  position: absolute; top: -6rpx; right: -6rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; line-height: 1;
}
.avatar-add {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 160rpx; height: 160rpx; border-radius: 24rpx;
  background: #F7F9F7; border: 2rpx dashed #C8E6C9;
}
.avatar-add-icon { font-size: 44rpx; }
.avatar-add-text { font-size: 22rpx; color: #90A4AE; margin-top: 4rpx; }
