/* pages/add-plant/add-plant.wxss */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  color: #999;
  font-size: 28rpx;
  padding: 4rpx 8rpx;
}

.camera-btn {
  width: 76rpx;
  height: 76rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 分类 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  background: #fff;
  font-size: 26rpx;
  color: #666;
}

.category-item.active {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
}

.cat-emoji {
  margin-right: 8rpx;
}

/* 植物列表 */
.plant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plant-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx !important;
}

.plant-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.plant-desc {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.plant-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.plant-latin {
  font-size: 22rpx;
  color: #bbb;
  font-style: italic;
  margin-top: 2rpx;
}

.plant-tags {
  display: flex;
  margin-top: 10rpx;
}

.plant-difficulty {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.diff-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.diff-text {
  font-size: 22rpx;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
}

.modal-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-body {
  padding: 20rpx 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.location-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.loc-opt {
  padding: 14rpx 24rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.loc-opt.active {
  background: #E8F5E9;
  color: #4CAF50;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer view {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
}

.btn-cancel {
  color: #999;
}

.btn-primary {
  color: #4CAF50;
  font-weight: 600;
}
