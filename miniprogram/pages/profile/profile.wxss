/* pages/profile/profile.wxss — v3 + 家庭模式入口 */
.pf-header { text-align: center; padding: 48rpx 28rpx !important; }
.pf-avatar {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex; align-items: center; justify-content: center;
  font-size: 70rpx; margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(76,175,80,0.15);
  position: relative; overflow: hidden;
}
.pf-avatar-img { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }
.pf-avatar-camera {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: rgba(0,0,0,0.35); text-align: center;
  font-size: 20rpx; padding: 4rpx 0; color: #fff;
}
.pf-name { font-size: 34rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 28rpx; }

.pf-stats { display: flex; justify-content: center; gap: 60rpx; }
.pf-stat { display: flex; flex-direction: column; align-items: center; }
.pf-num { font-size: 40rpx; font-weight: 700; color: #4CAF50; }
.pf-label { font-size: 24rpx; color: #90A4AE; margin-top: 4rpx; }

.section-title {
  display: flex; align-items: center;
  font-size: 30rpx; font-weight: 600; color: #2D3436;
  margin-bottom: 20rpx; padding: 8rpx;
}
.ach-count { margin-left: 12rpx; font-size: 24rpx; color: #4CAF50; font-weight: 400; }
.toggle-arrow { margin-left: auto; font-size: 24rpx; color: #90A4AE; }

.ach-progress { margin-left: 12rpx; font-size: 24rpx; color: #4CAF50; font-weight: 400; }
.progress-bar-wrap { padding: 0 8rpx; margin-bottom: 20rpx; }
.progress-bar { height: 12rpx; background: #F0F2F0; border-radius: 6rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #4CAF50, #66BB6A); border-radius: 6rpx; transition: width 0.5s ease; }

.ach-series { margin-bottom: 16rpx; }
.series-header { padding: 12rpx 12rpx 8rpx; display: flex; align-items: baseline; gap: 12rpx; }
.series-name { font-size: 28rpx; font-weight: 600; color: #2D3436; }
.series-desc { font-size: 22rpx; color: #90A4AE; }

.ach-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.ach-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 20rpx 8rpx; border-radius: 16rpx; text-align: center;
}
.ach-item.unlocked { background: #F1F8E9; }
.ach-item.locked { background: #F7F9F7; opacity: 0.7; }
.ach-emoji { font-size: 44rpx; margin-bottom: 8rpx; }
.ach-name { font-size: 22rpx; font-weight: 600; color: #2D3436; margin-bottom: 4rpx; }
.ach-desc { font-size: 18rpx; color: #90A4AE; }

.family-group { margin-bottom: 4rpx; }
.family-header-row { display: flex; align-items: center; gap: 14rpx; padding: 12rpx 0; }
.family-bar-name { font-size: 26rpx; color: #2D3436; width: 104rpx; text-align: right; font-weight: 500; }
.family-bar-wrap { flex: 1; height: 16rpx; background: #F0F2F0; border-radius: 8rpx; overflow: hidden; }
.family-bar-fill { height: 100%; border-radius: 8rpx; background: linear-gradient(90deg, #4CAF50, #66BB6A); }
.family-bar-count { font-size: 24rpx; color: #4CAF50; font-weight: 500; min-width: 56rpx; text-align: right; }
.family-arrow { font-size: 28rpx; color: #B0BEC5; transition: transform 0.2s; }
.family-arrow.expanded { transform: rotate(90deg); }
.family-plants { background: #F7F9F7; border-radius: 12rpx; padding: 12rpx 16rpx; margin: 4rpx 0 12rpx; }
.family-plant-item { display: flex; align-items: center; gap: 10rpx; padding: 10rpx 0; border-bottom: 1rpx solid #E8F5E9; }
.family-plant-item:last-child { border-bottom: none; }
.family-plant-emoji { font-size: 24rpx; }
.family-plant-name { font-size: 26rpx; color: #2D3436; font-weight: 500; }
.family-plant-loc { font-size: 22rpx; color: #90A4AE; margin-left: auto; }

.setting-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.setting-row:last-child { border-bottom: none; }
.setting-label { font-size: 28rpx; color: #2D3436; }
.setting-value { font-size: 28rpx; color: #4CAF50; }
.setting-arrow { color: #B0BEC5; font-size: 32rpx; }

.func-row {
  display: flex; align-items: center;
  padding: 28rpx; border-bottom: 1rpx solid #F0F2F0;
}
.func-row:last-child { border-bottom: none; }
.func-row:active { background: #F7F9F7; }
.func-icon { font-size: 32rpx; margin-right: 20rpx; }
.func-name { flex: 1; font-size: 28rpx; color: #2D3436; }
.func-arrow { color: #B0BEC5; font-size: 32rpx; }
.func-row.danger .func-name { color: #5D4037; }

.empty-hint { text-align: center; padding: 20rpx; color: #90A4AE; font-size: 26rpx; }

.stat-row { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; border-bottom: 1rpx solid #F0F2F0; }
.stat-row:last-of-type { border-bottom: none; }
.stat-label { font-size: 28rpx; color: #2D3436; }
.stat-value { font-size: 28rpx; }/* 花费统计 */
.cost-overview { display: flex; justify-content: space-around; padding: 12rpx 0; }
.cost-item { text-align: center; }
.cost-num { font-size: 32rpx; font-weight: 700; color: #FF9800; display: block; }
.cost-label { font-size: 22rpx; color: #B0BEC5; }
.cost-record { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #F0F2F0; }
.cost-record:last-child { border-bottom: none; }
.cost-record-left { flex: 1; }
.cost-record-name { font-size: 26rpx; font-weight: 500; display: block; }
.cost-record-note { font-size: 22rpx; color: #90A4AE; display: block; margin-top: 2rpx; }
.cost-record-right { text-align: right; }
.cost-record-amount { font-size: 28rpx; font-weight: 700; color: #FF9800; display: block; }
.cost-record-date { font-size: 20rpx; color: #B0BEC5; display: block; }
.cost-action-btns {
  display: flex; gap: 16rpx; margin-top: 20rpx;
}
.cost-action-btn {
  flex: 1; text-align: center; padding: 16rpx 0;
  background: #F7F9F7; border: 2rpx solid #C8E6C9; border-radius: 16rpx;
  font-size: 26rpx; color: #2E7D32; font-weight: 500;
}
.cost-action-btn:active { background: #E8F5E9; }
