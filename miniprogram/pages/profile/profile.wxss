/* pages/profile/profile.wxss — v2 */
.profile-header { text-align: center; padding: 48rpx 28rpx !important; }
.avatar {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex; align-items: center; justify-content: center;
  font-size: 70rpx; margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(76,175,80,0.15);
}
.profile-name { font-size: 34rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 28rpx; }

.stats-row { display: flex; justify-content: center; gap: 60rpx; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #4CAF50; }
.stat-label { font-size: 24rpx; color: #90A4AE; margin-top: 4rpx; }

/* 花园分布 */
.section-title { font-size: 30rpx; font-weight: 600; color: #2D3436; margin-bottom: 20rpx; }
.cat-list { display: flex; flex-direction: column; gap: 14rpx; }
.cat-item { display: flex; align-items: center; gap: 14rpx; }
.cat-name { font-size: 26rpx; color: #90A4AE; min-width: 56rpx; }
.cat-bar-wrap { flex: 1; height: 16rpx; background: #F0F2F0; border-radius: 8rpx; overflow: hidden; }
.cat-bar {
  height: 100%; border-radius: 8rpx;
  background: linear-gradient(90deg, #4CAF50, #66BB6A);
  transition: width 0.3s ease;
}
.cat-count { font-size: 24rpx; color: #4CAF50; font-weight: 500; min-width: 56rpx; text-align: right; }

/* 设置 */
.setting-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.setting-item:last-child { border-bottom: none; }
.setting-label { font-size: 28rpx; color: #2D3436; }
.setting-value { font-size: 28rpx; color: #4CAF50; }

/* 功能列表 */
.func-list { padding: 0 !important; }
.func-item {
  display: flex; align-items: center;
  padding: 28rpx 28rpx; border-bottom: 1rpx solid #F0F2F0;
  transition: background 0.15s;
}
.func-item:last-child { border-bottom: none; }
.func-item:active { background: #F7F9F7; }
.func-icon { font-size: 32rpx; margin-right: 20rpx; }
.func-name { flex: 1; font-size: 28rpx; color: #2D3436; }
.func-arrow { color: #B0BEC5; font-size: 32rpx; }
.func-item.danger .func-name { color: #FF7043; }
