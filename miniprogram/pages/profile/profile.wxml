<!-- pages/profile/profile.wxml - v3 成就系统 + 家庭管理 -->
<view class="container">
  <!-- 头像和统计 -->
  <view class="card pf-header">
    <view class="pf-avatar" bindtap="changeAvatar">
      <image wx:if="{{userAvatar}}" class="pf-avatar-img" src="{{userAvatar}}" mode="aspectFill" />
      <text wx:else>{{inFamily ? '🏠' : '🌱'}}</text>
      <view class="pf-avatar-camera">📷</view>
    </view>
    <text class="pf-name">{{inFamily ? familyName || '家庭花园' : '养花达人'}}</text>
    <view class="pf-stats" wx:if="{{!statsLoading}}">
      <view class="pf-stat">
        <text class="pf-num">{{stats.totalPlants || 0}}</text>
        <text class="pf-label">棵植物</text>
      </view>
      <view class="pf-stat">
        <text class="pf-num">{{stats.totalRecords || 0}}</text>
        <text class="pf-label">条记录</text>
      </view>
      <view class="pf-stat">
        <text class="pf-num">{{careStreak}}</text>
        <text class="pf-label">天连续</text>
      </view>
      <view class="pf-stat">
        <text class="pf-num">{{retroRemaining}}</text>
        <text class="pf-label">次补卡</text>
      </view>
    </view>
  </view>

  <!-- 家庭模式入口 -->
  <view class="card" bindtap="goFamily" style="background: linear-gradient(135deg, #E8F5E9, #C8E6C9);">
    <view class="setting-row" style="border-bottom:none">
      <view style="display:flex;align-items:center">
        <text style="font-size:32rpx;margin-right:16rpx">🏠</text>
        <view>
          <text class="setting-label">{{inFamily ? familyName : '家庭管理'}}</text>
          <text style="font-size:22rpx;color:#78909C">{{inFamily ? '已加入家庭' : '创建或加入家庭'}}</text>
        </view>
      </view>
      <text class="setting-arrow">{{inFamily ? '管理' : '›'}}</text>
    </view>
  </view>

  <!-- 成就总进度 -->
  <view class="section-title" bindtap="toggleAchievements">
    <text>🏆 成就</text>
    <text class="ach-progress">{{achProgress.done}}/{{achProgress.total}} · {{achProgress.percent}}%</text>
    <text class="toggle-arrow">{{showAchievements ? '收起' : '展开'}}</text>
  </view>

  <view class="progress-bar-wrap" wx:if="{{!showAchievements}}">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{achProgress.percent}}%"></view>
    </view>
  </view>

  <view wx:if="{{showAchievements}}">
    <view class="ach-series" wx:for="{{achGroups}}" wx:key="index" wx:for-item="group" wx:for-index="seriesKey">
      <view class="series-header">
        <text class="series-name">{{group.name}}</text>
        <text class="series-desc">{{group.desc}}</text>
      </view>
      <view class="card">
        <view class="ach-grid">
          <view class="ach-item {{item.unlocked ? 'unlocked' : 'locked'}}"
                wx:for="{{group.achievements}}" wx:key="id">
            <text class="ach-emoji">{{item.unlocked ? item.emoji : '🔒'}}</text>
            <text class="ach-name">{{item.unlocked ? item.name : '???'}}</text>
            <text class="ach-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 花园分布（按科） -->
  <view class="card">
    <view class="section-title">🌳 按科分布</view>
    <view class="family-group" wx:for="{{familyList}}" wx:key="name">
      <view class="family-header-row" bindtap="toggleFamily" data-name="{{item.name}}">
        <text class="family-bar-name">{{item.name}}</text>
        <view class="family-bar-wrap">
          <view class="family-bar-fill" style="width: {{item.percent}}%"></view>
        </view>
        <text class="family-bar-count">{{item.count}}棵</text>
        <text class="family-arrow {{expandedFamily===item.name?'expanded':''}}">›</text>
      </view>
      <!-- 展开的植物列表 -->
      <view class="family-plants" wx:if="{{expandedFamily===item.name}}">
        <view class="family-plant-item" wx:for="{{item.plants}}" wx:for-item="plant" wx:key="id" bindtap="goPlantDetail" data-id="{{plant.id}}">
          <text class="family-plant-emoji">{{plant.emoji}}</text>
          <text class="family-plant-name">{{plant.name}}</text>
          <text class="family-plant-loc" wx:if="{{plant.location}}">{{plant.location}}</text>
        </view>
      </view>
    </view>
    <view class="empty-hint" wx:if="{{!familyList || familyList.length === 0}}">
      <text>还没有植物哦~</text>
    </view>
  </view>

  <!-- 月度统计 -->
  <view class="section-title">📊 本月养护</view>
  <view class="card">
    <view class="stat-row" wx:for="{{monthlyStats}}" wx:key="label">
      <text class="stat-label">{{item.emoji}} {{item.label}}</text>
      <text class="stat-value" style="color:#4CAF50;font-weight:600">{{item.value}}</text>
    </view>
    <view style="display:flex;align-items:flex-end;height:120rpx;gap:8rpx;margin-top:16rpx">
      <view wx:for="{{weekBars}}" wx:key="day" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4rpx">
        <view style="width:100%;height:{{item.height}};background:#E8F5E9;border-radius:6rpx 6rpx 0 0;min-height:8rpx"></view>
        <text style="font-size:18rpx;color:#B0BEC5">{{item.day}}</text>
      </view>
    </view>
  </view>

  <!-- 花费统计 -->
  <view class="section-title">💰 花费统计</view>
  <view class="card" wx:if="{{costStats}}">
    <view class="cost-overview">
      <view class="cost-item">
        <text class="cost-num">¥{{costStats.totalAll || '0'}}</text>
        <text class="cost-label">总花费</text>
      </view>
      <view class="cost-item">
        <text class="cost-num">¥{{costStats.totalPurchase || '0'}}</text>
        <text class="cost-label">购入({{costStats.plantCount}}棵)</text>
      </view>
      <view class="cost-item">
        <text class="cost-num">¥{{costStats.totalMaintenance || '0'}}</text>
        <text class="cost-label">维护</text>
      </view>
    </view>
  </view>



  <!-- 月度花费趋势 -->
  <view class="card" wx:if="{{monthlyCost.length > 0}}">
    <view class="section-title" style="padding:4px 0"><text>📈 维护花费趋势</text></view>
    <view style="display:flex;align-items:flex-end;height:100rpx;gap:8rpx;margin-top:12rpx">
      <view wx:for="{{monthlyCost}}" wx:key="month" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4rpx">
        <text style="font-size:18rpx;color:#FF9800" wx:if="{{item.cost > 0}}">¥{{item.cost}}</text>
        <view style="width:100%;height:{{item.height}};background:#FFF3E0;border-radius:6rpx 6rpx 0 0;min-height:8rpx"></view>
        <text style="font-size:18rpx;color:#B0BEC5">{{item.month}}</text>
      </view>
    </view>
  </view>

  <!-- 最近花费记录 -->
  <view class="card" wx:if="{{recentCosts.length > 0}}">
    <view class="section-title" style="padding:4px 0"><text>🧾 最近花费</text></view>
    <view class="cost-record" wx:for="{{recentCosts}}" wx:key="id">
      <view class="cost-record-left">
        <text class="cost-record-name">{{item.plantName}}</text>
        <text class="cost-record-note">{{item.note || item.typeName}}</text>
      </view>
      <view class="cost-record-right">
        <text class="cost-record-amount">¥{{item.cost}}</text>
        <text class="cost-record-date">{{item.dateStr}}</text>
      </view>
    </view>
  </view>

  <!-- 功能 -->
  <view class="section-title">⚙️ 设置</view>
  <view class="card">
    <view class="setting-row">
      <text class="setting-label">养护提醒</text>
      <switch checked="{{settings.reminderEnabled}}" bindchange="toggleReminder" color="#4CAF50" />
    </view>
    <view class="setting-row">
      <text class="setting-label">提醒时间</text>
      <picker mode="time" value="{{settings.reminderTime}}" bindchange="changeReminderTime">
        <text class="setting-value">{{settings.reminderTime}} ›</text>
      </picker>
    </view>
  </view>

  <view class="card" style="padding:0;">
    <view class="func-row" bindtap="goDiagnose">
      <text class="func-icon">🩺</text>
      <text class="func-name">病害诊断</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-row" bindtap="syncToCloud" wx:if="{{!inFamily}}">
      <text class="func-icon">☁️</text>
      <text class="func-name">备份到云端</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-row" bindtap="syncFromCloud" wx:if="{{!inFamily}}">
      <text class="func-icon">📥</text>
      <text class="func-name">从云端恢复</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-row" bindtap="exportGardenReport">
      <text class="func-icon">📤</text>
      <text class="func-name">导出花园报告</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-row" bindtap="showAbout">
      <text class="func-icon">ℹ️</text>
      <text class="func-name">关于养花助手</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-row danger" bindtap="clearData">
      <text class="func-icon">🗑️</text>
      <text class="func-name">清除所有数据</text>
      <text class="func-arrow">›</text>
    </view>
  </view>
</view>