/* pages/index/index.wxss — 首页 v2 */
.section { margin-bottom: 24rpx; }

.section-title {
  display: flex; align-items: center;
  padding: 16rpx 8rpx; font-size: 32rpx; font-weight: 600; color: #2D3436;
}
.section-icon { margin-right: 8rpx; font-size: 34rpx; }

.badge {
  margin-left: 12rpx; background: #FF7043; color: #fff;
  font-size: 20rpx; padding: 2rpx 14rpx; border-radius: 20rpx; font-weight: 600;
}

/* 完成提示 toast */
.tip-toast {
  position: fixed; top: 100rpx; left: 50%; transform: translateX(-50%) translateY(-40rpx);
  background: rgba(38,166,154,0.95); color: #fff; padding: 16rpx 40rpx;
  border-radius: 44rpx; font-size: 26rpx; z-index: 999;
  opacity: 0; transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(38,166,154,0.3);
}
.tip-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* 统计条 */
.stats-bar { display: flex; gap: 12rpx; padding: 0 8rpx; margin-bottom: 16rpx; }
.stat-chip {
  padding: 8rpx 20rpx; background: #FFFFFF; border-radius: 20rpx;
  font-size: 22rpx; color: #90A4AE;
  box-shadow: 0 2rpx 12rpx rgba(76,175,80,0.05);
}

/* 今日任务 */
.task-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.task-item:last-child { border-bottom: none; }
.task-info { display: flex; align-items: center; flex: 1; }
.task-emoji { font-size: 44rpx; margin-right: 20rpx; }
.task-detail { display: flex; flex-direction: column; }
.task-name { font-size: 28rpx; font-weight: 500; color: #2D3436; }
.task-time { font-size: 24rpx; color: #4CAF50; margin-top: 4rpx; }
.task-time.overdue { color: #FF7043; font-weight: 600; }
.task-btn {
  background: #E8F5E9; color: #4CAF50; padding: 10rpx 28rpx;
  border-radius: 44rpx; font-size: 24rpx; font-weight: 600;
  transition: all 0.2s;
}
.task-btn:active { background: #C8E6C9; transform: scale(0.95); }

/* 植物列表 */
.plant-grid { display: flex; flex-direction: column; gap: 12rpx; }
.plant-card {
  display: flex; align-items: center;
  padding: 24rpx 28rpx !important;
  transition: transform 0.15s;
}
.plant-card:active { transform: scale(0.98); }

.plant-avatar {
  width: 84rpx; height: 84rpx; border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx; flex-shrink: 0;
}
.plant-avatar.needs-care { background: linear-gradient(135deg, #FFF3E0, #FFE0B2); }
.plant-emoji { font-size: 42rpx; }

.plant-info { flex: 1; display: flex; flex-direction: column; }
.plant-name { font-size: 30rpx; font-weight: 600; color: #2D3436; }
.plant-species { font-size: 24rpx; color: #90A4AE; margin-top: 4rpx; }

.plant-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.plant-status { font-size: 38rpx; }
.due-badge {
  background: #FF7043; color: #fff; font-size: 20rpx;
  min-width: 32rpx; height: 32rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  padding: 0 8rpx; font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 60rpx; text-align: center;
}
.empty-state .emoji { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-state .title { font-size: 32rpx; font-weight: 600; color: #2D3436; margin-bottom: 12rpx; }
.empty-state .desc { font-size: 26rpx; color: #90A4AE; margin-bottom: 36rpx; }
