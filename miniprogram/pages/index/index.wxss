/* pages/index/index.wxss — 首页 v5（骨架屏+动画） */

/* 骨架屏 */
.skeleton { padding: 24rpx 28rpx; }
.sk-title { width: 120rpx; height: 36rpx; background: #F0F2F0; border-radius: 8rpx; margin-bottom: 20rpx; }
.sk-card { background: #FFF; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 2rpx 16rpx rgba(76,175,80,0.05); }
.sk-row { display: flex; align-items: center; padding: 20rpx 0; }
.sk-circle { width: 56rpx; height: 56rpx; border-radius: 50%; background: #F0F2F0; margin-right: 20rpx; flex-shrink: 0; }
.sk-lines { flex: 1; }
.sk-line { height: 24rpx; background: #F0F2F0; border-radius: 6rpx; margin-bottom: 8rpx; }
.sk-line:last-child { margin-bottom: 0; }
.sk-line.long { width: 60%; }
.sk-line.short { width: 35%; }
.sk-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.sk-item { display: flex; flex-direction: column; align-items: center; padding: 20rpx 8rpx; }
.sk-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: #F0F2F0; margin-bottom: 12rpx; }
.sk-name { width: 60rpx; height: 24rpx; background: #F0F2F0; border-radius: 6rpx; }

/* 骨架屏动画 */
.skeleton .sk-title,
.skeleton .sk-circle,
.skeleton .sk-line,
.skeleton .sk-avatar,
.skeleton .sk-name {
  background: linear-gradient(90deg, #F0F2F0 25%, #E8EAE8 50%, #F0F2F0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* 内容淡入 */
.content-fade { animation: fadeIn 0.3s ease-out; }
.content-fade.hidden { display: none; }
@keyframes fadeIn { from{opacity:0;transform:translateY(16rpx)} to{opacity:1;transform:translateY(0)} }

/* 完成任务动画 */
.task-item.completing {
  animation: slideOut 0.3s ease-out forwards;
}
@keyframes slideOut { to{opacity:0;transform:translateX(60rpx);height:0;padding:0;overflow:hidden} }
.section { margin-bottom: 24rpx; }

.section-title {
  display: flex; align-items: center;
  padding: 16rpx 8rpx; font-size: 32rpx; font-weight: 600; color: #2D3436;
}
.section-icon { margin-right: 8rpx; font-size: 34rpx; }

.badge {
  margin-left: 12rpx; background: #2E7D32; color: #fff;
  font-size: 20rpx; padding: 2rpx 14rpx; border-radius: 20rpx; font-weight: 600;
}
.complete-all {
  margin-left: auto; font-size: 24rpx; color: #4CAF50; font-weight: 500;
}

/* 完成提示 toast */
.tip-toast {
  position: fixed; top: 100rpx; left: 50%; transform: translateX(-50%) translateY(-40rpx);
  background: rgba(38,166,154,0.95); color: #fff; padding: 16rpx 40rpx;
  border-radius: 44rpx; font-size: 26rpx; z-index: 999;
  opacity: 0; transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(38,166,154,0.3);
}
.tip-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* 统计条 */
/* 天气卡片 */
.weather-card { display: flex; align-items: center; gap: 12rpx; background: linear-gradient(135deg, #E3F2FD, #BBDEFB); border-radius: 14rpx; padding: 16rpx 20rpx; margin: 0 8rpx 12rpx; }
.weather-card.error { background: linear-gradient(135deg, #FFF3E0, #FFE0B2); }
.weather-emoji { font-size: 32rpx; }
.weather-temp { font-size: 28rpx; font-weight: 700; color: #1565C0; }
.weather-desc { font-size: 24rpx; color: #1976D2; }
.weather-detail { font-size: 22rpx; color: #64B5F6; margin-left: auto; }
.weather-error { font-size: 20rpx; color: #E65100; flex: 1; text-align: right; }

.stats-bar { display: flex; gap: 12rpx; padding: 0 8rpx; margin-bottom: 16rpx; }
.stat-chip {
  padding: 8rpx 20rpx; background: #FFFFFF; border-radius: 20rpx;
  font-size: 22rpx; color: #90A4AE;
  box-shadow: 0 2rpx 12rpx rgba(76,175,80,0.05);
}

/* 搜索栏 */
.search-bar { margin-bottom: 16rpx; }
.search-wrap {
  display: flex; align-items: center; background: #FFFFFF;
  border-radius: 44rpx; padding: 14rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(76,175,80,0.05);
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #2D3436; }
.search-clear { font-size: 28rpx; color: #90A4AE; padding: 4rpx 12rpx; }

/* 房间标签栏 */
.room-scroll {
  display: flex; white-space: nowrap; margin-bottom: 16rpx;
}
.room-tag {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 10rpx 24rpx; margin-right: 12rpx;
  border-radius: 44rpx; font-size: 24rpx; color: #607D8B;
  background: #F7F9F7; flex-shrink: 0;
}
.room-tag.active {
  background: linear-gradient(135deg, #4CAF50, #66BB6A); color: white;
  font-weight: 600;
}
.room-tag.add {
  background: #FFFFFF; color: #4CAF50; font-size: 28rpx; font-weight: 600;
  border: 2rpx dashed #C8E6C9; min-width: 56rpx;
}

/* 今日任务 */
.task-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.task-item:last-child { border-bottom: none; }
.task-info { display: flex; align-items: center; flex: 1; }
.task-emoji { font-size: 44rpx; margin-right: 20rpx; }
.task-detail { display: flex; flex-direction: column; }
.task-name { font-size: 28rpx; font-weight: 500; }
.task-time { font-size: 24rpx; color: #4CAF50; margin-top: 4rpx; }
.task-time.overdue { color: #2E7D32; font-weight: 600; }
.task-btn {
  background: #E8F5E9; color: #4CAF50; padding: 10rpx 28rpx;
  border-radius: 44rpx; font-size: 24rpx; font-weight: 600;
  transition: all 0.2s;
}
.task-btn:active { background: #C8E6C9; transform: scale(0.95); }

/* 花园矩阵网格 */
.garden-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx;
}
.garden-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 20rpx 8rpx; border-radius: 20rpx; background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(76,175,80,0.05);
  transition: transform 0.15s;
}
.garden-item:active { transform: scale(0.95); }

.garden-avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx; position: relative; overflow: hidden;
}
.garden-avatar.needs-care { background: linear-gradient(135deg, #E8F5E9, #C8E6C9); }
.garden-avatar-img { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }
.garden-emoji { font-size: 44rpx; z-index: 1; }
.garden-due {
  position: absolute; top: -4rpx; right: -4rpx;
  background: #2E7D32; color: #fff; font-size: 18rpx;
  min-width: 28rpx; height: 28rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: 600; z-index: 2; padding: 0 6rpx;
}
.garden-name {
  font-size: 24rpx; color: #2D3436; font-weight: 500;
  max-width: 100%; overflow: hidden; text-overflow: ellipsis;
  white-space: nowrap; text-align: center;
}
.garden-location {
  font-size: 18rpx; color: #B0BEC5; margin-top: 2rpx;
}

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 60rpx; text-align: center;
}
.empty-state.small { padding: 40rpx 60rpx; }
.empty-state .emoji { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-state .title { font-size: 32rpx; font-weight: 600; color: #2D3436; margin-bottom: 12rpx; }
.empty-state .desc { font-size: 26rpx; color: #90A4AE; margin-bottom: 36rpx; }
.btn-primary {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white; padding: 20rpx 60rpx; border-radius: 44rpx;
  font-size: 30rpx; font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(76,175,80,0.25);
}

/* 弹窗 */
.modal-mask {
  position: fixed; top:0;left:0;right:0;bottom:0;
  background:rgba(0,0,0,0.45); display:flex;
  align-items:center; justify-content:center; z-index:999;
}
.modal-content {
  width: 80%; background: #FFFFFF; border-radius: 28rpx;
  overflow: hidden;
}
.modal-header { padding: 36rpx 30rpx 12rpx; text-align: center; }
.modal-title { font-size: 32rpx; font-weight: 600; color: #2D3436; }
.modal-body { padding: 16rpx 40rpx 28rpx; }
.form-input {
  border: 2rpx solid #E8F5E9; border-radius: 20rpx;
  padding: 20rpx; font-size: 28rpx; background: #F7F9F7; color: #2D3436;
}
.modal-footer { display: flex; border-top: 1rpx solid #F0F2F0; }
.modal-footer view { flex: 1; text-align: center; padding: 30rpx; font-size: 30rpx; }
.btn-cancel { color: #90A4AE; }

/* 家庭模式头部 */
.family-header-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 16rpx 12rpx;
}
.family-header-left { display: flex; align-items: center; }
.family-header-icon { font-size: 36rpx; margin-right: 12rpx; }
.family-header-info { display: flex; flex-direction: column; }
.family-header-title { font-size: 30rpx; font-weight: 700; color: #2E7D32; }
/* 死亡植物 */
.dead-plant { opacity: 0.55; }
.dead-plant .garden-name { text-decoration: line-through; color: #B0BEC5; }
.dead-avatar { filter: grayscale(100%); }
