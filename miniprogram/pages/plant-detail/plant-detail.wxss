/* pages/plant-detail/plant-detail.wxss - 重构版 */
.plant-header { text-align: center; }
.header-main { display: flex; align-items: center; margin-bottom: 24rpx; }
.header-emoji { font-size: 100rpx; margin-right: 30rpx; }
.header-info { flex: 1; display: flex; flex-direction: column; text-align: left; }
.header-name { font-size: 36rpx; font-weight: 700; color: #333; }
.header-species { font-size: 24rpx; color: #999; font-style: italic; margin-top: 4rpx; }
.header-location { font-size: 24rpx; color: #666; margin-top: 8rpx; }

.header-actions { display: flex; justify-content: center; gap: 16rpx; flex-wrap: wrap; }
.action-btn {
  padding: 12rpx 24rpx; border-radius: 30rpx; background: #f5f5f5;
  font-size: 24rpx; color: #666;
}
.action-btn.danger { color: #FF5252; background: #FFEBEE; }

/* 任务区 */
.section-title {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 30rpx; font-weight: 600; padding: 20rpx 10rpx;
}
.add-link { font-size: 26rpx; color: #4CAF50; font-weight: 400; }

.task-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.task-row:last-child { border-bottom: none; }
.task-left { display: flex; align-items: center; flex: 1; }
.task-emoji { font-size: 36rpx; margin-right: 16rpx; }
.task-info { display: flex; flex-direction: column; }
.task-name { font-size: 28rpx; font-weight: 500; }
.task-name.disabled { color: #bbb; text-decoration: line-through; }
.task-status { font-size: 24rpx; color: #4CAF50; margin-top: 4rpx; }
.task-status.overdue { color: #FF5252; font-weight: 600; }

.task-right { display: flex; align-items: center; gap: 12rpx; }
.interval-ctrl {
  display: flex; align-items: center; gap: 4rpx;
  background: #f5f5f5; border-radius: 20rpx; padding: 4rpx 8rpx;
}
.ctrl-btn { width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #666; }
.ctrl-value { font-size: 24rpx; color: #333; min-width: 50rpx; text-align: center; }

.done-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%; background: #E8F5E9;
  color: #4CAF50; display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
}
.done-btn.highlight { background: #4CAF50; color: #fff; animation: pulse 1.5s infinite; }
.pause-btn { font-size: 28rpx; padding: 8rpx; }

@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }

.empty-hint { text-align: center; padding: 30rpx; color: #999; font-size: 26rpx; }

/* Tab */
.tabs { display: flex; margin: 20rpx 0; background: #fff; border-radius: 16rpx; padding: 6rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx; border-radius: 12rpx; font-size: 26rpx; color: #666; }
.tab.active { background: #E8F5E9; color: #4CAF50; font-weight: 600; }

/* 养护信息 */
.care-item { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.care-item:last-child { border-bottom: none; }
.care-label { font-size: 28rpx; color: #666; }
.care-value { font-size: 28rpx; color: #333; text-align: right; max-width: 400rpx; }

/* 养护记录 */
.record-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; position: relative; }
.record-item:last-child { border-bottom: none; }
.record-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%; background: #4CAF50;
  margin-right: 20rpx; margin-top: 10rpx; flex-shrink: 0;
}
.record-content { display: flex; flex-direction: column; flex: 1; }
.record-type { font-size: 28rpx; font-weight: 500; }
.record-note { font-size: 26rpx; color: #666; margin-top: 4rpx; }
.record-time { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }

/* 小贴士 */
.tip-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.tip-item:last-child { border-bottom: none; }
.tip-bullet { margin-right: 12rpx; font-size: 28rpx; }
.tip-text { font-size: 28rpx; color: #555; line-height: 1.6; }

/* 弹窗 */
.modal-mask { position: fixed; top:0;left:0;right:0;bottom:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:999; }
.modal-content { width: 620rpx; background: #fff; border-radius: 24rpx; overflow: hidden; }
.modal-header { padding: 36rpx 30rpx 16rpx; text-align: center; }
.modal-title { font-size: 32rpx; font-weight: 600; }
.modal-body { padding: 20rpx 40rpx; }
.form-item { margin-bottom: 30rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 12rpx; display: block; }
.form-input { border: 2rpx solid #e0e0e0; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; }

.type-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.type-opt { padding: 12rpx 20rpx; border-radius: 24rpx; background: #f5f5f5; font-size: 24rpx; }
.type-opt.active { background: #E8F5E9; color: #4CAF50; }

.modal-footer { display: flex; border-top: 1rpx solid #f0f0f0; }
.modal-footer view { flex: 1; text-align: center; padding: 28rpx; font-size: 30rpx; }
.btn-cancel { color: #999; }
.btn-primary { color: #4CAF50; font-weight: 600; }
