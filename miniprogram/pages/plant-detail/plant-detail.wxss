/* pages/plant-detail/plant-detail.wxss — v3 */

/* 骨架屏 */
.skeleton { padding: 12rpx; }
.skeleton .card { background: #FFF; border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 16rpx rgba(76,175,80,0.05); }
.skeleton .sk-row { display: flex; align-items: center; padding: 16rpx 0; gap: 20rpx; }
.skeleton .sk-circle-lg { width: 96rpx; height: 96rpx; border-radius: 50%; background: linear-gradient(90deg, #F0F2F0 25%, #E8EAE8 50%, #F0F2F0 75%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; flex-shrink: 0; }
.skeleton .sk-circle-sm { width: 48rpx; height: 48rpx; border-radius: 50%; background: linear-gradient(90deg, #F0F2F0 25%, #E8EAE8 50%, #F0F2F0 75%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; flex-shrink: 0; }
.skeleton .sk-lines-lg { flex: 1; }
.skeleton .sk-lines { flex: 1; }
.skeleton .sk-line { height: 24rpx; background: linear-gradient(90deg, #F0F2F0 25%, #E8EAE8 50%, #F0F2F0 75%); background-size: 200% 100%; border-radius: 6rpx; margin-bottom: 8rpx; }
.skeleton .sk-line:last-child { margin-bottom: 0; }
.skeleton .sk-line.long { width: 60%; }
.skeleton .sk-line.short { width: 35%; }.plant-header { text-align: center; }
.header-main { display: flex; align-items: center; margin-bottom: 24rpx; }

.header-avatar {
  width: 168rpx; height: 168rpx; border-radius: 50%; margin-right: 28rpx;
  position: relative; flex-shrink: 0;
  background: linear-gradient(135deg, #66BB6A, #4CAF50);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(76,175,80,0.15);
  padding: 4rpx;
}
.header-avatar-img {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  position: relative; z-index: 1;
}
.header-emoji-text {
  position: relative; z-index: 1;
  font-size: 64rpx;
  width: 160rpx; height: 160rpx;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 50%;
}
.header-avatar-img {
  width: 100%; height: 100%; position: absolute; top: 0; left: 0;
}
.avatar-camera {
  position: absolute; bottom: 4rpx; right: 4rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); display: flex;
  align-items: center; justify-content: center;
  font-size: 20rpx; z-index: 2;
}
.header-info { flex: 1; display: flex; flex-direction: column; text-align: left; }
.header-name-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 12rpx; }
.header-name { font-size: 40rpx; font-weight: 800; color: #2D3436; line-height: 1.2; }

/* 次要信息标签区 */
.header-meta { display: flex; flex-direction: column; gap: 10rpx; }
.meta-row { display: flex; align-items: center; gap: 6rpx; }
.meta-icon { font-size: 22rpx; flex-shrink: 0; }
.meta-text { font-size: 24rpx; color: #636e72; }
.meta-sub { font-size: 22rpx; color: #b2bec3; margin-left: 4rpx; }
.price-text { color: #FF9800; font-weight: 700; font-size: 28rpx; }

.header-actions { display: flex; justify-content: center; gap: 14rpx; flex-wrap: wrap; margin-top: 24rpx; }
.action-btn {
  padding: 14rpx 28rpx; border-radius: 44rpx;
  background: #F7F9F7; font-size: 24rpx; color: #90A4AE;
  transition: all 0.15s;
}
.action-btn:active { transform: scale(0.95); }
/* 浇水按钮：绿底白字，最突出 */
.action-btn.water {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.25);
}
.action-btn.water:active { opacity: 0.9; }
/* 拍照按钮：次突出 */
.action-btn:first-child {
  background: #E8F5E9;
  color: #2E7D32;
  font-weight: 500;
}
.action-btn.danger { color: #5D4037; background: #EFEBE9; }
.action-btn.danger:active { background: #D7CCC8; }

/* 任务区 */.add-link { font-size: 26rpx; color: #4CAF50; font-weight: 500; }

.task-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.task-row:last-child { border-bottom: none; }
.task-left { display: flex; align-items: center; flex: 1; }
.task-emoji { font-size: 36rpx; margin-right: 16rpx; }
.task-info { display: flex; flex-direction: column; }
.task-name { font-size: 28rpx; font-weight: 500; color: #2D3436; }
.task-name.disabled { color: #B0BEC5; text-decoration: line-through; }
.task-status { font-size: 24rpx; color: #4CAF50; margin-top: 4rpx; }
.task-status.overdue { color: #E53935; font-weight: 700; }

/* 逾期任务整行高亮 */
.task-row.task-overdue {
  background: #FFF8F8;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  margin: 8rpx -16rpx;
  border-left: 6rpx solid #EF5350;
}

.task-right { display: flex; align-items: center; gap: 12rpx; }
.interval-ctrl {
  display: flex; align-items: center; gap: 4rpx;
  background: #F7F9F7; border-radius: 44rpx; padding: 4rpx 8rpx;
}
.ctrl-btn {
  width: 56rpx; height: 56rpx; display: flex;
  align-items: center; justify-content: center;
  font-size: 28rpx; color: #90A4AE;
}
.ctrl-value { font-size: 24rpx; color: #2D3436; min-width: 48rpx; text-align: center; font-weight: 500; }

.done-btn {
  min-width: 72rpx; min-height: 72rpx; border-radius: 50%;
  background: #E8F5E9; color: #4CAF50;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
  transition: all 0.15s;
}
.done-btn:active { transform: scale(0.9); }
.done-btn.highlight {
  background: #EF5350; color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(239,83,80,0.35);
  animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }

.pause-btn { font-size: 28rpx; padding: 8rpx; color: #90A4AE; }

.empty-hint { text-align: center; padding: 28rpx; color: #90A4AE; font-size: 26rpx; }

/* Tab — 圆角16rpx */
.tabs {
  display: flex; margin: 16rpx 0; background: #FFFFFF;
  border-radius: 16rpx; padding: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(76,175,80,0.05);
}
.tab {
  flex: 1; text-align: center; padding: 16rpx;
  border-radius: 12rpx; font-size: 26rpx; color: #90A4AE;
  transition: all 0.2s;
}
.tab.active { background: #E8F5E9; color: #4CAF50; font-weight: 600; }

/* 养护信息 */
.care-item {
  display: flex; justify-content: space-between;
  padding: 14rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.care-item:last-child { border-bottom: none; }
.care-label { font-size: 28rpx; color: #90A4AE; }
.care-value { font-size: 28rpx; color: #2D3436; text-align: right; max-width: 400rpx; }

/* 养护记录 — 时间线 */
.record-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx; padding: 0 8rpx;
}
.record-title {
  font-size: 30rpx; font-weight: 600; color: #333;
}
.import-btn {
  font-size: 26rpx; color: #4CAF50; background: #F0FFF0;
  padding: 10rpx 24rpx; border-radius: 44rpx;
}
/* 日历热力图 */
.cal-cell {
  width: 14.28%; display: flex; flex-direction: column; align-items: center;
  height: 80rpx; justify-content: center; position: relative;
}

/* 时间线样式 */
.tl { }
.tl-month {
  font-size: 26rpx; font-weight: 600; color: #4CAF50;
  padding: 20rpx 0 8rpx; border-bottom: 1rpx solid #E8F5E9;
  margin-bottom: 12rpx;
}
.tl-month:first-child { padding-top: 4rpx; }
.tl-day { margin-bottom: 16rpx; }
.tl-day-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 4rpx 0 8rpx;
}
.tl-day-label { font-size: 24rpx; color: #78909C; font-weight: 500; }
.tl-day-label.today { color: #4CAF50; font-weight: 600; }
.tl-day-count { font-size: 20rpx; color: #B0BEC5; }
.tl-capsules { display: flex; flex-wrap: wrap; gap: 10rpx; }
.capsule {
  display: inline-flex; align-items: center; gap: 6rpx;
  background: #F1F8E9; border-radius: 24rpx;
  padding: 8rpx 16rpx; font-size: 24rpx;
  border: 1rpx solid #E8F5E9;
}
.capsule-emoji { font-size: 22rpx; }
.capsule-name { font-weight: 500; }
.capsule-note { color: #90A4AE; font-size: 20rpx; max-width: 200rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.capsule-creator { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 8rpx; margin-left: auto; white-space: nowrap; }
/* 弹窗遮罩：居中 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 999;
  display: flex; align-items: center; justify-content: center;
}
.modal-content {
  width: 620rpx; max-height: 80vh; background: #FFFFFF; border-radius: 28rpx;
  overflow: hidden; animation: scaleIn 0.25s ease-out;
  display: flex; flex-direction: column;
}
@keyframes scaleIn { from{opacity:0;transform:scale(0.9)} to{opacity:1;transform:scale(1)} }.modal-body { padding: 16rpx 40rpx 28rpx; overflow-y: auto; flex: 1; }.type-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.type-opt {
  padding: 12rpx 24rpx; border-radius: 44rpx;
  background: #F7F9F7; font-size: 24rpx; color: #90A4AE;
  transition: all 0.2s;
}
.type-opt.active { background: #E8F5E9; color: #4CAF50; font-weight: 600; }.btn-primary { color: #4CAF50; font-weight: 600; }

/* 编辑入口 */
.edit-icon { font-size: 24rpx; opacity: 0.5; }
.edit-icon-sm { font-size: 28rpx; color: #90A4AE; margin-left: 8rpx; }

/* 智能贴士 */
.tip-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8rpx 16rpx 12rpx;
}
.tip-weather { font-size: 24rpx; color: #4CAF50; font-weight: 500; }
.tip-fresh { font-size: 20rpx; color: #B0BEC5; background: #F7F9F7; padding: 4rpx 12rpx; border-radius: 16rpx; }
.tip-empty { text-align: center; padding: 40rpx; color: #B0BEC5; font-size: 26rpx; }

/* 健康评分 */
.health-bar {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 0; margin-top: 8rpx;
}
.health-emoji { font-size: 28rpx; }
.health-label { font-size: 24rpx; font-weight: 600; }
.health-progress {
  flex: 1; height: 8rpx; background: #F0F2F0; border-radius: 4rpx; overflow: hidden;
}
.health-fill { height: 100%; border-radius: 4rpx; transition: width 0.5s ease; }
.health-num { font-size: 22rpx; font-weight: 600; min-width: 60rpx; text-align: right; }

/* 认养 */
.adopt-section { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid #f0f0f0; }
.adopt-info { display: flex; align-items: center; margin-bottom: 16rpx; }
.adopt-label { font-size: 24rpx; color: #888; }
.adopt-names { font-size: 24rpx; color: #4CAF50; font-weight: 500; }
.adopt-btn { text-align: center; padding: 16rpx; border-radius: 24rpx; font-size: 26rpx; background: #E8F5E9; color: #4CAF50; border: 2rpx solid #C8E6C9; }
.adopt-btn.adopted { background: #4CAF50; color: #fff; border-color: #4CAF50; }
.adopt-btn:active { opacity: 0.8; }

/* 操作者标签 */
.record-creator { font-size: 22rpx; color: #4CAF50; background: #E8F5E9; padding: 2rpx 12rpx; border-radius: 10rpx; margin-left: 12rpx; }
/* 价格信息 - 已合并到 meta-row */
.price-add { color: #4CAF50; font-size: 24rpx; }

/* 学名行 + 放大镜 */
.species-row { gap: 12rpx; flex-wrap: wrap; }
.header-species { font-size: 24rpx; color: #81C784; font-style: italic; }
.species-tag { font-size: 20rpx; background: #F1F8E9; color: #558B2F; padding: 2rpx 10rpx; border-radius: 6rpx; }
.search-icon { font-size: 28rpx; opacity: 0.6; padding: 4rpx 8rpx; }
.search-icon:active { opacity: 1; }

/* 操作菜单：居中弹窗 */
.action-sheet { width: 560rpx; background: #fff; border-radius: 28rpx; overflow: hidden; z-index: 1000; animation: scaleIn 0.25s ease-out; }
.action-item { padding: 30rpx; text-align: center; font-size: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.action-item:active { background: #f5f5f5; }
.action-item.cancel { color: #999; border-bottom: none; margin-top: 8rpx; }

/* 分类弹窗 */
.classify-modal { max-height: 85vh; display: flex; flex-direction: column; }
.search-results { max-height: 300rpx; overflow-y: auto; margin: 16rpx 0; }
.search-item { padding: 20rpx 24rpx; border-bottom: 1rpx solid #f5f5f5; font-size: 28rpx; color: #333; }
.search-item:active { background: #f5f5f5; }

/* 识别结果列表 */
.classify-list { flex: 1; overflow-y: auto; max-height: 55vh; }
.classify-item { padding: 16rpx 12rpx; border-bottom: 1rpx solid #f0f0f0; border-radius: 12rpx; margin-bottom: 8rpx; }
.classify-item.selected { background: #E8F5E9; border: 2rpx solid #4CAF50; }
.classify-item-header { display: flex; align-items: center; gap: 12rpx; }
.classify-check { font-size: 32rpx; }
.classify-name { font-size: 30rpx; font-weight: bold; color: #2D3436; flex: 1; }
.classify-score { font-size: 24rpx; color: #4CAF50; font-weight: 600; }
.classify-tags { display: flex; gap: 8rpx; margin-top: 8rpx; padding-left: 44rpx; }
.classify-tag { font-size: 22rpx; background: #E8F5E9; color: #2E7D32; padding: 4rpx 14rpx; border-radius: 8rpx; }
.classify-desc { display: block; font-size: 22rpx; color: #999; margin-top: 6rpx; padding-left: 44rpx; line-height: 1.4; max-height: 80rpx; overflow: hidden; }

/* 大按钮 */
.modal-btns-lg { display: flex; gap: 20rpx; margin-top: 24rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.btn-lg { flex: 1; text-align: center; padding: 24rpx; border-radius: 16rpx; font-size: 32rpx; font-weight: 600; }
.btn-lg.cancel { background: #f5f5f5; color: #666; }
.btn-lg.cancel:active { background: #e8e8e8; }
.btn-lg.confirm { background: #4CAF50; color: #fff; }
.btn-lg.confirm:active { background: #388E3C; }

/* 填写分类居中弹窗 */
.classify-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; display: flex; align-items: center; justify-content: center; }
.classify-sheet { width: 620rpx; background: #fff; border-radius: 28rpx; padding: 32rpx; max-height: 75vh; display: flex; flex-direction: column; animation: scaleIn 0.25s ease-out; }
.classify-sheet-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.classify-sheet-title { font-size: 34rpx; font-weight: bold; color: #2D3436; }
.classify-sheet-close { font-size: 32rpx; color: #999; padding: 8rpx 16rpx; }
.classify-input-wrap { background: #F5F5F5; border-radius: 16rpx; padding: 4rpx; }
.classify-input { width: 100%; padding: 20rpx 24rpx; font-size: 30rpx; box-sizing: border-box; height: 88rpx; }
.classify-results { max-height: 40vh; overflow-y: auto; margin-top: 12rpx; }
.classify-result-item { display: flex; align-items: center; gap: 16rpx; padding: 24rpx 16rpx; border-bottom: 1rpx solid #f5f5f5; }
.classify-result-item:active { background: #F1F8E9; }
.classify-result-icon { font-size: 32rpx; }
.classify-result-text { font-size: 30rpx; color: #2D3436; }
.classify-no-result { text-align: center; padding: 40rpx; font-size: 26rpx; color: #999; }
.classify-sheet-footer { display: flex; gap: 20rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
/* 死亡植物 */
.dead-avatar { filter: grayscale(100%) opacity(0.5); }
.dead-badge { font-size: 22rpx; background: #FFEBEE; color: #C62828; padding: 4rpx 12rpx; border-radius: 16rpx; margin-left: 8rpx; }
.action-btn.dead { background: #FFEBEE; color: #C62828; }
.action-btn.revive { background: #E8F5E9; color: #4CAF50; }
.dead-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; font-size: 48rpx; background: rgba(0,0,0,0.35); border-radius: 50%; }

/* 施肥类型弹窗 */
.fertilize-modal { max-height: 70vh; }
.fert-tags { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 20rpx 0; }
.fert-tag { padding: 12rpx 28rpx; border-radius: 32rpx; font-size: 26rpx; background: #f0f0f0; color: #333; }
.fert-tag.active { background: #4CAF50; color: #fff; }
.fert-input-row { padding: 16rpx 0; }
.fert-input { width: 100%; height: 88rpx; border: 2rpx solid #ddd; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; line-height: 88rpx; }

/* 房间弹窗 */
.room-modal { max-height: 70vh; }
.room-tags { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 20rpx 0; }
.room-tag { padding: 12rpx 28rpx; border-radius: 32rpx; font-size: 26rpx; background: #f0f0f0; color: #333; }
.room-tag.active { background: #4CAF50; color: #fff; }
.room-input-row { padding: 16rpx 0; }
.room-input { width: 100%; height: 88rpx; border: 2rpx solid #ddd; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; line-height: 88rpx; }

/* 价格弹窗 */
.price-modal { max-height: 70vh; }
.price-field { display: flex; align-items: center; margin: 16rpx 0; }
.price-field-label { font-size: 28rpx; color: #666; width: 80rpx; flex-shrink: 0; }
.price-field-input { flex: 1; height: 88rpx; border: 2rpx solid #ddd; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; line-height: 88rpx; }
.source-tags { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 12rpx 0; }
.source-tag { padding: 10rpx 24rpx; border-radius: 32rpx; font-size: 24rpx; background: #f0f0f0; color: #333; }
.source-tag.active { background: #FF9800; color: #fff; }

/* 补浇水弹窗 */
.retro-water-modal { max-height: 80vh; }
.retro-water-subtitle {
  display: block;
  font-size: 24rpx;
  color: #90A4AE;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
}
.retro-water-dates {
  max-height: 50vh;
  overflow-y: auto;
}
.retro-date-item {
  display: flex;
  align-items: center;
  padding: 22rpx 16rpx;
  border-bottom: 1rpx solid #F0F2F0;
  gap: 16rpx;
}
.retro-date-item:active { background: #F5F5F5; }
.retro-date-item.active {
  background: #E3F2FD;
  border-radius: 12rpx;
}
.retro-date-label {
  font-size: 30rpx;
  color: #2D3436;
  font-weight: 500;
  flex: 1;
}
.retro-date-week {
  font-size: 24rpx;
  color: #90A4AE;
}
.retro-date-check {
  font-size: 28rpx;
  color: #1565C0;
  font-weight: 700;
}
.retro-water-custom {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #F0F2F0;
  margin-top: 12rpx;
}
.retro-water-custom-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}
.retro-water-custom-picker {
  font-size: 28rpx;
  color: #1565C0;
  padding: 8rpx 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

/* 到家日期选择器 */
.date-picker-value {
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

/* 到家日期 - 已合并到 meta-row */
