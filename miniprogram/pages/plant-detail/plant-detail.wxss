/* pages/plant-detail/plant-detail.wxss — v3 */

/* 骨架屏 */
.skeleton { padding: 12rpx; }
.skeleton .card { background: #FFF; border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 16rpx rgba(76,175,80,0.05); }
.skeleton .sk-row { display: flex; align-items: center; padding: 16rpx 0; gap: 20rpx; }
.skeleton .sk-circle-lg { width: 96rpx; height: 96rpx; border-radius: 50%; background: linear-gradient(90deg, #F0F2F0 25%, #E8EAE8 50%, #F0F2F0 75%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; flex-shrink: 0; }
.skeleton .sk-circle-sm { width: 48rpx; height: 48rpx; border-radius: 50%; background: linear-gradient(90deg, #F0F2F0 25%, #E8EAE8 50%, #F0F2F0 75%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; flex-shrink: 0; }
.skeleton .sk-lines-lg { flex: 1; }
.skeleton .sk-lines { flex: 1; }
.skeleton .sk-line { height: 24rpx; background: linear-gradient(90deg, #F0F2F0 25%, #E8EAE8 50%, #F0F2F0 75%); background-size: 200% 100%; border-radius: 6rpx; margin-bottom: 8rpx; }
.skeleton .sk-line:last-child { margin-bottom: 0; }
.skeleton .sk-line.long { width: 60%; }
.skeleton .sk-line.short { width: 35%; }
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
.content-fade { animation: fadeIn 0.3s ease-out; }
@keyframes fadeIn { from{opacity:0;transform:translateY(16rpx)} to{opacity:1;transform:translateY(0)} }

.plant-header { text-align: center; }
.header-main { display: flex; align-items: center; margin-bottom: 24rpx; }

.header-avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%; margin-right: 28rpx;
  position: relative; overflow: hidden; flex-shrink: 0;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex; align-items: center; justify-content: center;
}
.header-avatar-img {
  width: 100%; height: 100%; position: absolute; top: 0; left: 0;
}
.header-emoji-text {
  font-size: 48rpx; z-index: 1;
}
.avatar-camera {
  position: absolute; bottom: 0; right: 0;
  width: 32rpx; height: 32rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); display: flex;
  align-items: center; justify-content: center;
  font-size: 18rpx; z-index: 2;
}
.header-info { flex: 1; display: flex; flex-direction: column; text-align: left; }
.header-name { font-size: 36rpx; font-weight: 700; color: #2D3436; }
.header-species { font-size: 22rpx; color: #B0BEC5; font-style: italic; margin-top: 4rpx; }
.header-location { font-size: 24rpx; color: #90A4AE; margin-top: 8rpx; }

.header-actions { display: flex; justify-content: center; gap: 14rpx; flex-wrap: wrap; }
.action-btn {
  padding: 12rpx 24rpx; border-radius: 44rpx;
  background: #F7F9F7; font-size: 24rpx; color: #90A4AE;
  transition: all 0.15s;
}
.action-btn:active { background: #E8F5E9; color: #4CAF50; }
.action-btn.danger { color: #5D4037; background: #EFEBE9; }
.action-btn.danger:active { background: #D7CCC8; }

/* 任务区 */
.section-title {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 30rpx; font-weight: 600; color: #2D3436; padding: 16rpx 8rpx;
}
.add-link { font-size: 26rpx; color: #4CAF50; font-weight: 500; }

.task-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.task-row:last-child { border-bottom: none; }
.task-left { display: flex; align-items: center; flex: 1; }
.task-emoji { font-size: 36rpx; margin-right: 16rpx; }
.task-info { display: flex; flex-direction: column; }
.task-name { font-size: 28rpx; font-weight: 500; color: #2D3436; }
.task-name.disabled { color: #B0BEC5; text-decoration: line-through; }
.task-status { font-size: 24rpx; color: #4CAF50; margin-top: 4rpx; }
.task-status.overdue { color: #2E7D32; font-weight: 600; }

.task-right { display: flex; align-items: center; gap: 12rpx; }
.interval-ctrl {
  display: flex; align-items: center; gap: 4rpx;
  background: #F7F9F7; border-radius: 44rpx; padding: 4rpx 8rpx;
}
.ctrl-btn {
  width: 40rpx; height: 40rpx; display: flex;
  align-items: center; justify-content: center;
  font-size: 28rpx; color: #90A4AE;
}
.ctrl-value { font-size: 24rpx; color: #2D3436; min-width: 48rpx; text-align: center; font-weight: 500; }

.done-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #E8F5E9; color: #4CAF50;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
  transition: all 0.15s;
}
.done-btn:active { transform: scale(0.9); }
.done-btn.highlight {
  background: #4CAF50; color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.3);
  animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }

.pause-btn { font-size: 28rpx; padding: 8rpx; color: #90A4AE; }

.empty-hint { text-align: center; padding: 28rpx; color: #90A4AE; font-size: 26rpx; }

/* Tab — 圆角16rpx */
.tabs {
  display: flex; margin: 16rpx 0; background: #FFFFFF;
  border-radius: 16rpx; padding: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(76,175,80,0.05);
}
.tab {
  flex: 1; text-align: center; padding: 16rpx;
  border-radius: 12rpx; font-size: 26rpx; color: #90A4AE;
  transition: all 0.2s;
}
.tab.active { background: #E8F5E9; color: #4CAF50; font-weight: 600; }

/* 养护信息 */
.care-item {
  display: flex; justify-content: space-between;
  padding: 14rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.care-item:last-child { border-bottom: none; }
.care-label { font-size: 28rpx; color: #90A4AE; }
.care-value { font-size: 28rpx; color: #2D3436; text-align: right; max-width: 400rpx; }

/* 养护记录 — 时间线 */
.record-item {
  display: flex; padding: 14rpx 0;
  border-bottom: 1rpx solid #F0F2F0; position: relative;
}
.record-item:last-child { border-bottom: none; }
.record-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%; background: #4CAF50;
  margin-right: 20rpx; margin-top: 10rpx; flex-shrink: 0;
}
.record-content { display: flex; flex-direction: column; flex: 1; }
.record-type { font-size: 28rpx; font-weight: 500; color: #2D3436; }
.record-note { font-size: 26rpx; color: #90A4AE; margin-top: 4rpx; }
.record-time { font-size: 22rpx; color: #B0BEC5; margin-top: 4rpx; }

/* 小贴士 */
.tip-item { display: flex; padding: 14rpx 0; border-bottom: 1rpx solid #F0F2F0; }
.tip-item:last-child { border-bottom: none; }
.tip-bullet { margin-right: 12rpx; font-size: 28rpx; }
.tip-text { font-size: 28rpx; color: #2D3436; line-height: 1.6; }

/* 弹窗 */
.modal-mask {
  position: fixed; top:0;left:0;right:0;bottom:0;
  background:rgba(0,0,0,0.45); display:flex;
  align-items:flex-end; justify-content:center; z-index:999;
  animation: fadeIn 0.2s ease;
}
.modal-content {
  width: 100%; background: #FFFFFF; border-radius: 28rpx 28rpx 0 0;
  overflow: hidden; animation: slideUp 0.3s ease-out;
}
.modal-header { padding: 36rpx 30rpx 12rpx; text-align: center; }
.modal-title { font-size: 32rpx; font-weight: 600; color: #2D3436; }
.modal-body { padding: 16rpx 40rpx 28rpx; }
.form-item { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; color: #90A4AE; margin-bottom: 12rpx; display: block; }
.form-input {
  border: 2rpx solid #E8F5E9; border-radius: 20rpx;
  padding: 20rpx; font-size: 28rpx; background: #F7F9F7; color: #2D3436;
}

.type-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.type-opt {
  padding: 12rpx 24rpx; border-radius: 44rpx;
  background: #F7F9F7; font-size: 24rpx; color: #90A4AE;
  transition: all 0.2s;
}
.type-opt.active { background: #E8F5E9; color: #4CAF50; font-weight: 600; }

.modal-footer { display: flex; border-top: 1rpx solid #F0F2F0; }
.modal-footer view { flex: 1; text-align: center; padding: 30rpx; font-size: 30rpx; }
.btn-cancel { color: #90A4AE; }
.btn-primary { color: #4CAF50; font-weight: 600; }

/* 编辑入口 */
.header-name-row { display: flex; align-items: center; gap: 8rpx; }
.edit-icon { font-size: 24rpx; opacity: 0.5; }
.header-location-row { display: flex; align-items: center; }
.edit-icon-sm { font-size: 28rpx; color: #90A4AE; margin-left: 8rpx; }

/* 智能贴士 */
.tip-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8rpx 16rpx 12rpx;
}
.tip-weather { font-size: 24rpx; color: #4CAF50; font-weight: 500; }
.tip-fresh { font-size: 20rpx; color: #B0BEC5; background: #F7F9F7; padding: 4rpx 12rpx; border-radius: 16rpx; }
.tip-empty { text-align: center; padding: 40rpx; color: #B0BEC5; font-size: 26rpx; }

/* 健康评分 */
.health-bar {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 0; margin-top: 8rpx;
}
.health-emoji { font-size: 28rpx; }
.health-label { font-size: 24rpx; font-weight: 600; }
.health-progress {
  flex: 1; height: 8rpx; background: #F0F2F0; border-radius: 4rpx; overflow: hidden;
}
.health-fill { height: 100%; border-radius: 4rpx; transition: width 0.5s ease; }
.health-num { font-size: 22rpx; font-weight: 600; min-width: 60rpx; text-align: right; }

