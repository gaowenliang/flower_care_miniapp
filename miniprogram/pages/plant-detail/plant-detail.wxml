<!-- pages/plant-detail/plant-detail.wxml - 重构版 -->
<view class="container" wx:if="{{userPlant}}">
  <!-- 骨架屏 -->
  <view class="skeleton" wx:if="{{loading}}">
    <view class="card" style="padding:20rpx">
      <view class="sk-row"><view class="sk-circle-lg"></view><view class="sk-lines-lg"><view class="sk-line long"></view><view class="sk-line short"></view><view class="sk-line short"></view></view></view>
    </view>
    <view style="height:24rpx"></view>
    <view class="card"><view class="sk-row"><view class="sk-circle-sm"></view><view class="sk-lines"><view class="sk-line long"></view><view class="sk-line short"></view></view></view><view class="sk-row"><view class="sk-circle-sm"></view><view class="sk-lines"><view class="sk-line long"></view><view class="sk-line short"></view></view></view><view class="sk-row"><view class="sk-circle-sm"></view><view class="sk-lines"><view class="sk-line long"></view><view class="sk-line short"></view></view></view></view>
    <view class="tabs" style="margin:16rpx 0;background:#FFF;border-radius:16rpx;padding:8rpx">
      <view style="height:40rpx;background:#F0F2F0;border-radius:12rpx;flex:1"></view>
    </view>
    <view class="card"><view class="sk-row" style="justify-content:space-between"><view class="sk-line" style="width:30%"></view><view class="sk-line" style="width:40%"></view></view><view class="sk-row" style="justify-content:space-between"><view class="sk-line" style="width:30%"></view><view class="sk-line" style="width:40%"></view></view><view class="sk-row" style="justify-content:space-between"><view class="sk-line" style="width:30%"></view><view class="sk-line" style="width:40%"></view></view></view>
  </view>
  <!-- 植物头部 -->
  <view class="plant-header card">
    <view class="header-main">
      <view class="header-avatar {{userPlant.dead ? 'dead-avatar' : ''}}" bindtap="changeAvatar">
        <image wx:if="{{userPlant.avatar}}" class="header-avatar-img" src="{{userPlant.avatar}}" mode="aspectFill" binderror="onAvatarError" />
        <text wx:else class="header-emoji-text">{{userPlant.dead ? '💀' : userPlant.emoji}}</text>
        <view class="dead-overlay" wx:if="{{userPlant.dead && userPlant.avatar}}">🪦</view>
        <view class="avatar-camera" wx:if="{{!userPlant.dead}}">📷</view>
      </view>
      <view class="header-info">
        <view class="header-name-row">
          <text class="header-name">{{userPlant.nickname}}</text>
          <text class="dead-badge" wx:if="{{userPlant.dead}}">💀 已嘎</text>
          <text class="edit-icon" bindtap="editNickname">✏️</text>
        </view>
        <view class="species-row">
          <text class="header-species">{{plantInfo.name}}{{plantInfo.latin ? ' · ' + plantInfo.latin : ''}}</text>
          <text class="species-tag" wx:if="{{plantInfo.family}}">{{plantInfo.family}}</text>
          <text class="species-tag" wx:if="{{plantInfo.genus}}">{{plantInfo.genus}}</text>
          <text class="search-icon" bindtap="showClassifyMenu">🔍</text>
        </view>
        <view class="header-location-row" bindtap="editLocation">
          <text class="header-location">📍 {{userPlant.location}} · {{plantInfo.category}}</text>
          <text class="edit-icon-sm">›</text>
        </view>
        <!-- 价格信息 -->
        <view class="header-price-row" wx:if="{{userPlant.purchasePrice > 0}}">
          <text class="price-label">💰 购入</text>
          <text class="price-value">¥{{userPlant.purchasePrice}}</text>
          <text class="price-date" wx:if="{{userPlant.purchaseDate}}"> · {{userPlant.purchaseDateStr || ''}}</text>
          <text class="price-source" wx:if="{{userPlant.purchaseSource}}"> · {{userPlant.purchaseSource}}</text>
          <text class="edit-icon-sm" bindtap="editPrice">✏️</text>
        </view>
        <view class="header-price-row" wx:else>
          <text class="price-add" bindtap="editPrice">+ 添加购入价格</text>
        </view>
      </view>
    </view>
    <!-- 健康评分 -->
    <view class="health-bar" wx:if="{{healthScore !== undefined}}">
      <text class="health-emoji">{{healthLevel.emoji}}</text>
      <text class="health-label" style="color:{{healthLevel.color}}">{{healthLevel.label}}</text>
      <view class="health-progress">
        <view class="health-fill" style="width:{{healthScore}}%;background:{{healthLevel.color}}"></view>
      </view>
      <text class="health-num" style="color:{{healthLevel.color}}">{{healthScore}}分</text>
    </view>
    <!-- 家庭模式：认养信息 -->
    <view class="adopt-section" wx:if="{{isFamilyMode}}">
      <view class="adopt-info" wx:if="{{adopterNames.length > 0}}">
        <text class="adopt-label">👤 认养：</text>
        <text class="adopt-names">{{adopterNames.join('、')}}</text>
      </view>
      <view class="adopt-btn {{isAdoptedByMe ? 'adopted' : ''}}" bindtap="toggleAdopt">
        {{isAdoptedByMe ? '💚 已认养' : '🤝 认养这棵植物'}}
      </view>
    </view>
    <view class="header-actions">
      <view class="action-btn" bindtap="takePhoto">📷 拍照</view>
      <view class="action-btn" bindtap="goJournal">📖 日记</view>
      <view class="action-btn" bindtap="shareReport">📤 报告</view>
      <view class="action-btn" bindtap="goDiagnose">🩺 诊断</view>
      <view class="action-btn" bindtap="showAddTaskModal">➕ 任务</view>
      <view class="action-btn" bindtap="retroCard">🔖 补卡</view>
      <view class="action-btn danger" bindtap="deletePlant">🗑️</view>
      <view class="action-btn {{userPlant.dead ? 'revive' : 'dead'}}" bindtap="markDead">{{userPlant.dead ? '🌱 复活' : '💀'}}</view>
    </view>
  </view>

  <!-- 养护任务 -->
  <view class="section">
    <view class="section-title">
      <text>📋 养护任务</text>
      <text class="add-link" bindtap="showAddTaskModal">+ 添加</text>
    </view>
    <view class="card" wx:if="{{tasks.length > 0}}">
      <view class="task-row" wx:for="{{tasks}}" wx:key="id">
        <view class="task-left">
          <text class="task-emoji">{{item.type === 'water' ? '💧' : item.type === 'fertilize' ? '🧪' : item.type === 'prune' ? '✂️' : item.type === 'repot' ? '🏺' : '💉'}}</text>
          <view class="task-info">
            <text class="task-name {{item.enabled ? '' : 'disabled'}}">{{item.typeName}}</text>
            <text class="task-status {{item.isOverdue && item.enabled ? 'overdue' : ''}}">{{item.enabled ? item.statusText : '已暂停'}}</text>
          </view>
        </view>
        <view class="task-right">
          <view class="interval-ctrl" wx:if="{{item.enabled}}">
            <text class="ctrl-btn" bindtap="changeInterval" data-task-id="{{item.id}}" data-delta="-1">−</text>
            <text class="ctrl-value">{{item.intervalDays}}天</text>
            <text class="ctrl-btn" bindtap="changeInterval" data-task-id="{{item.id}}" data-delta="1">+</text>
          </view>
          <view class="done-btn {{item.isOverdue && item.enabled ? 'highlight' : ''}}" bindtap="completeTask" data-id="{{item.id}}" wx:if="{{item.enabled}}">✓</view>
          <view class="pause-btn" bindtap="toggleTask" data-id="{{item.id}}">
            {{item.enabled ? '⏸' : '▶'}}
          </view>
        </view>
      </view>
    </view>
    <view class="card empty-hint" wx:else>
      <text>还没有养护任务，点击"添加"创建一个吧~</text>
    </view>
  </view>

  <!-- Tab -->
  <view class="tabs">
    <view class="tab {{activeTab === 'care' ? 'active' : ''}}" bindtap="switchTab" data-tab="care">养护指南</view>
    <view class="tab {{activeTab === 'record' ? 'active' : ''}}" bindtap="switchTab" data-tab="record">养护记录</view>
    <view class="tab {{activeTab === 'tips' ? 'active' : ''}}" bindtap="switchTab" data-tab="tips">小贴士</view>
  </view>

  <!-- 养护指南 -->
  <view class="tab-content" wx:if="{{activeTab === 'care' && plantInfo}}">
    <view class="card">
      <view class="care-item" wx:for="{{[
        {label:'☀️ 光照', value: plantInfo.care.light},
        {label:'💧 浇水', value: '每' + plantInfo.care.waterDays + '天，' + plantInfo.care.waterAmount},
        {label:'🌡️ 温度', value: plantInfo.care.temperature},
        {label:'💦 湿度', value: plantInfo.care.humidity},
        {label:'🏺 土壤', value: plantInfo.care.soil},
        {label:'🧪 施肥', value: plantInfo.care.fertilizer},
        {label:'⚡ 难度', value: plantInfo.care.difficulty}
      ]}}" wx:key="label">
        <text class="care-label">{{item.label}}</text>
        <text class="care-value">{{item.value}}</text>
      </view>
      <view class="care-item" wx:if="{{plantInfo.care.toxicity}}">
        <text class="care-label">⚠️ 安全</text>
        <text class="care-value">{{plantInfo.care.toxicity}}</text>
      </view>
    </view>
  </view>

  <!-- 养护记录 -->
  <view class="tab-content" wx:if="{{activeTab === 'record'}}">
    <view class="record-header">
      <text class="record-title">养护记录</text>
      <text class="import-btn" bindtap="goImportScreenshot">📥 导入记录</text>
    </view>
    <view class="card" wx:if="{{records.length > 0}}">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-dot"></view>
        <view class="record-content">
          <text class="record-type">{{item.typeName}}</text>
          <text class="record-creator" wx:if="{{isFamilyMode && item.creatorNickname}}">by {{item.creatorNickname}}</text>
          <text class="record-note" wx:if="{{item.note}}">{{item.note}}</text>
          <text class="record-time">{{item.timeAgo}} · {{item.dateText}}</text>
        </view>
      </view>
    </view>
    <view class="card empty-hint" wx:else>
      <text>还没有养护记录</text>
    </view>
  </view>

  <!-- 小贴士（智能） -->
  <view class="tab-content" wx:if="{{activeTab === 'tips'}}">
    <view class="tip-header" wx:if="{{tipWeather}}">
      <text class="tip-weather">🌤️ {{tipWeather}} · {{tipDate}}</text>
      <text class="tip-fresh">每日更新</text>
    </view>
    <view class="card">
      <view class="tip-item" wx:for="{{smartTips}}" wx:key="index">
        <text class="tip-bullet">💡</text>
        <text class="tip-text">{{item}}</text>
      </view>
      <view class="tip-empty" wx:if="{{smartTips.length === 0}}">
        <text>贴士加载中...</text>
      </view>
    </view>
  </view>

  <!-- 添加任务弹窗 -->
  <view class="modal-mask" wx:if="{{showAddTask}}" bindtap="hideAddTaskModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">添加养护任务</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">任务类型</text>
          <view class="type-options">
            <view class="type-opt {{newTaskType === item.id ? 'active' : ''}}" 
                  wx:for="{{taskTypes}}" wx:key="id"
                  bindtap="selectTaskType" data-type="{{item.id}}">
              <text>{{item.emoji}} {{item.name}}</text>
            </view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">间隔天数</text>
          <input class="form-input" type="number" value="{{newTaskInterval}}" bindinput="onIntervalInput" />
        </view>
      </view>
      <view class="modal-footer">
        <view class="btn-cancel" bindtap="hideAddTaskModal">取消</view>
        <view class="btn-primary" bindtap="confirmAddTask">确认添加</view>
      </view>
    </view>
  </view>

  <!-- 分类操作菜单 -->
  <view class="modal-mask" wx:if="{{showClassifyAction}}" bindtap="hideClassifyMenu">
    <view class="action-sheet" catchtap="">
      <view class="action-item" bindtap="openClassifySearch">📝 填写分类</view>
      <view class="action-item" bindtap="identifyAvatar">🤖 AI识别 - 头像</view>
      <view class="action-item" bindtap="identifyPhoto">📷 AI识别 - 照片</view>
      <view class="action-item cancel" bindtap="hideClassifyMenu">取消</view>
    </view>
  </view>

  <!-- 填写分类搜索 -->
  <view class="classify-mask" wx:if="{{showClassifySearch}}" bindtap="hideClassifySearch">
    <view class="classify-sheet" catchtap="">
      <view class="classify-sheet-header">
        <text class="classify-sheet-title">📝 填写分类</text>
        <view class="classify-sheet-close" bindtap="hideClassifySearch">✕</view>
      </view>
      <view class="classify-input-wrap">
        <input class="classify-input" placeholder="搜索或输入科名，如：百合科" value="{{classifySearchKey}}" bindinput="onClassifySearchInput" focus="{{showClassifySearch}}" />
      </view>
      <view class="classify-results" wx:if="{{classifySearchResults.length > 0}}">
        <view class="classify-result-item" wx:for="{{classifySearchResults}}" wx:key="*this" bindtap="selectFamily" data-family="{{item}}">
          <text class="classify-result-icon">🌿</text>
          <text class="classify-result-text">{{item}}</text>
        </view>
      </view>
      <view class="classify-no-result" wx:elif="{{classifySearchKey.length > 0}}">
        <text>未找到匹配，直接点确认使用「{{classifySearchKey}}」</text>
      </view>
      <view class="classify-sheet-footer">
        <view class="btn-lg cancel" bindtap="hideClassifySearch">取消</view>
        <view class="btn-lg confirm" bindtap="confirmClassifyInput">确认</view>
      </view>
    </view>
  </view>

  <!-- AI识别结果 -->
  <view class="modal-mask" wx:if="{{showClassifyResult}}" bindtap="hideClassifyResult">
    <view class="modal-content classify-modal" catchtap="preventBubble">
      <view class="modal-title">🤖 识别结果</view>
      <view class="classify-list">
        <view class="classify-item {{classifySelectedIdx === index ? 'selected' : ''}}" 
              wx:for="{{classifyResults}}" wx:key="index"
              bindtap="selectClassifyItem" data-idx="{{index}}">
          <view class="classify-item-header">
            <text class="classify-check">{{classifySelectedIdx === index ? '✅' : '⬜'}}</text>
            <text class="classify-name">{{item.name}}</text>
            <text class="classify-score">{{item.score}}%</text>
          </view>
          <view class="classify-tags" wx:if="{{item.family || item.genus}}">
            <text class="classify-tag" wx:if="{{item.family}}">{{item.family}}</text>
            <text class="classify-tag" wx:if="{{item.genus}}">{{item.genus}}</text>
          </view>
          <text class="classify-desc" wx:if="{{item.description}}">{{item.description}}</text>
        </view>
      </view>
      <view class="modal-btns-lg">
        <view class="btn-lg cancel" bindtap="hideClassifyResult">取消</view>
        <view class="btn-lg confirm" bindtap="applyClassifyResult">确认应用</view>
      </view>
    </view>
  </view>

  <!-- 施肥类型弹窗 -->
  <view class="modal-mask" wx:if="{{showFertilizeModal}}" bindtap="cancelFertilize">
    <view class="modal-content fertilize-modal" catchtap>
      <text class="modal-title">🌱 选择肥料类型</text>
      <view class="fert-tags">
        <view class="fert-tag {{fertilizeInput === item ? 'active' : ''}}" wx:for="{{fertilizeTypes}}" wx:key="*this" bindtap="selectFertilizeType" data-type="{{item}}">{{item}}</view>
      </view>
      <view class="fert-input-row" wx:if="{{fertilizeInput === '' || fertilizeTypes.indexOf(fertilizeInput) === fertilizeTypes.length - 1}}">
        <input class="fert-input" placeholder="输入肥料名称" value="{{fertilizeInput}}" bindinput="onFertilizeInput" />
      </view>
      <view class="modal-btns-lg">
        <view class="btn-lg cancel" bindtap="cancelFertilize">取消</view>
        <view class="btn-lg confirm" bindtap="confirmFertilize">确认</view>
      </view>
    </view>
  </view>
</view>
