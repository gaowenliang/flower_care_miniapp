<!-- pages/room-manage/room-manage.wxml -->
<view class="page">
  <view class="section-title">🏠 房间管理</view>

  <view class="room-list">
    <view class="room-card" wx:for="{{rooms}}" wx:key="name">
      <view class="room-info">
        <text class="room-name">{{item.name}}</text>
        <view class="room-env-tags" wx:if="{{item.env}}">
          <text class="env-tag">🌬️ {{item.env.ventilation}}</text>
          <text class="env-tag">☀️ {{item.env.lighting}}</text>
          <text class="env-tag">💧 {{item.env.humidity}}</text>
          <text class="env-tag">🌡️ {{item.env.temperature}}</text>
        </view>
        <text class="room-no-env" wx:else>未设置环境参数</text>
      </view>
      <view class="room-actions">
        <view class="action-btn env-btn" bindtap="editEnv" data-name="{{item.name}}">⚙️</view>
        <view class="action-btn del-btn" wx:if="{{!item.isPreset}}" bindtap="deleteRoom" data-name="{{item.name}}">🗑️</view>
      </view>
    </view>
  </view>

  <view class="add-room-btn" bindtap="showAdd">
    <text>+ 添加房间</text>
  </view>

  <!-- 添加弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="hideAdd">
    <view class="modal-content" catchtap="">
      <view class="modal-title">添加房间</view>
      <input class="modal-input" placeholder="输入房间名称，如：厨房、走廊..." maxlength="6" value="{{newRoomName}}" bindinput="onNameInput" focus="{{showAddModal}}" />
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="hideAdd">取消</view>
        <view class="modal-btn confirm" bindtap="confirmAdd">添加</view>
      </view>
    </view>
  </view>

  <!-- 环境参数弹窗 -->
  <view class="modal-mask" wx:if="{{showEnvModal}}" bindtap="hideEnvModal">
    <view class="modal-content env-modal" catchtap="preventBubble">
      <view class="modal-title">⚙️ {{editingRoom}}</view>

      <view class="env-row">
        <text class="env-label">🌬️ 通风</text>
        <view class="env-options">
          <text class="env-opt {{ventilation === '极差' ? 'active' : ''}}" bindtap="setEnv" data-key="ventilation" data-val="极差">极差</text>
          <text class="env-opt {{ventilation === '差' ? 'active' : ''}}" bindtap="setEnv" data-key="ventilation" data-val="差">差</text>
          <text class="env-opt {{ventilation === '一般' ? 'active' : ''}}" bindtap="setEnv" data-key="ventilation" data-val="一般">一般</text>
          <text class="env-opt {{ventilation === '良好' ? 'active' : ''}}" bindtap="setEnv" data-key="ventilation" data-val="良好">良好</text>
          <text class="env-opt {{ventilation === '极佳' ? 'active' : ''}}" bindtap="setEnv" data-key="ventilation" data-val="极佳">极佳</text>
        </view>
      </view>

      <view class="env-row">
        <text class="env-label">☀️ 采光</text>
        <view class="env-options">
          <text class="env-opt {{lighting === '阴暗' ? 'active' : ''}}" bindtap="setEnv" data-key="lighting" data-val="阴暗">阴暗</text>
          <text class="env-opt {{lighting === '弱光' ? 'active' : ''}}" bindtap="setEnv" data-key="lighting" data-val="弱光">弱光</text>
          <text class="env-opt {{lighting === '散射光' ? 'active' : ''}}" bindtap="setEnv" data-key="lighting" data-val="散射光">散射光</text>
          <text class="env-opt {{lighting === '明亮' ? 'active' : ''}}" bindtap="setEnv" data-key="lighting" data-val="明亮">明亮</text>
          <text class="env-opt {{lighting === '强光' ? 'active' : ''}}" bindtap="setEnv" data-key="lighting" data-val="强光">强光</text>
        </view>
      </view>

      <view class="env-row">
        <text class="env-label">💧 湿度</text>
        <view class="env-options">
          <text class="env-opt {{humidity === '极干' ? 'active' : ''}}" bindtap="setEnv" data-key="humidity" data-val="极干">极干</text>
          <text class="env-opt {{humidity === '干燥' ? 'active' : ''}}" bindtap="setEnv" data-key="humidity" data-val="干燥">干燥</text>
          <text class="env-opt {{humidity === '适中' ? 'active' : ''}}" bindtap="setEnv" data-key="humidity" data-val="适中">适中</text>
          <text class="env-opt {{humidity === '潮湿' ? 'active' : ''}}" bindtap="setEnv" data-key="humidity" data-val="潮湿">潮湿</text>
          <text class="env-opt {{humidity === '极潮' ? 'active' : ''}}" bindtap="setEnv" data-key="humidity" data-val="极潮">极潮</text>
        </view>
      </view>

      <view class="env-row">
        <text class="env-label">🌡️ 温度</text>
        <view class="env-options">
          <text class="env-opt {{temperature === '寒冷' ? 'active' : ''}}" bindtap="setEnv" data-key="temperature" data-val="寒冷">寒冷</text>
          <text class="env-opt {{temperature === '偏凉' ? 'active' : ''}}" bindtap="setEnv" data-key="temperature" data-val="偏凉">偏凉</text>
          <text class="env-opt {{temperature === '常温' ? 'active' : ''}}" bindtap="setEnv" data-key="temperature" data-val="常温">常温</text>
          <text class="env-opt {{temperature === '温暖' ? 'active' : ''}}" bindtap="setEnv" data-key="temperature" data-val="温暖">温暖</text>
          <text class="env-opt {{temperature === '炎热' ? 'active' : ''}}" bindtap="setEnv" data-key="temperature" data-val="炎热">炎热</text>
        </view>
      </view>

      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="hideEnvModal">取消</view>
        <view class="modal-btn confirm" bindtap="saveEnv">保存</view>
      </view>
    </view>
  </view>
</view>
