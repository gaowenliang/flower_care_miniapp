/* pages/calendar/calendar.wxss — v2 */
.month-nav {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 28rpx; background: #FFFFFF;
  border-radius: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(76,175,80,0.05);
}
.nav-btn {
  font-size: 28rpx; color: #4CAF50;
  padding: 12rpx 20rpx; border-radius: 44rpx;
  transition: all 0.15s;
}
.nav-btn:active { background: #E8F5E9; }
.month-text { font-size: 32rpx; font-weight: 600; color: #2D3436; }

/* 日历网格 */
.week-header { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; margin-bottom: 8rpx; }
.week-day { font-size: 24rpx; color: #90A4AE; padding: 8rpx 0; }

.days-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
.day-cell {
  display: flex; flex-direction: column; align-items: center;
  padding: 10rpx 0; border-radius: 16rpx; margin: 3rpx;
  min-height: 76rpx; transition: all 0.15s;
}
.day-cell.empty { pointer-events: none; }
.day-cell.today .day-num { color: #4CAF50; font-weight: 700; }
.day-cell.has-task { background: #F1F8E9; }
.day-cell.selected { background: #4CAF50; box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.2); }
.day-cell.selected .day-num { color: #FFFFFF; }
.day-cell:active { transform: scale(0.92); }

.day-num { font-size: 28rpx; color: #2D3436; }
.task-dots { display: flex; gap: 4rpx; margin-top: 4rpx; }
.dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: #4CAF50; }
.day-cell.selected .dot { background: rgba(255,255,255,0.8); }

/* 日期任务 */
.section-title { font-size: 30rpx; font-weight: 600; color: #2D3436; padding: 20rpx 8rpx 14rpx; }

.day-task-item {
  display: flex; align-items: center;
  padding: 14rpx 0; border-bottom: 1rpx solid #F0F2F0;
}
.day-task-item:last-child { border-bottom: none; }
.day-task-emoji { font-size: 36rpx; margin-right: 16rpx; }
.day-task-info { display: flex; flex-direction: column; }
.day-task-name { font-size: 28rpx; font-weight: 500; color: #2D3436; }
.day-task-type { font-size: 24rpx; color: #90A4AE; }

.empty-hint { text-align: center; padding: 36rpx; color: #90A4AE; font-size: 26rpx; }
