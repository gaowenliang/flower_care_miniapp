/* pages/calendar/calendar.wxss */
.month-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.nav-btn {
  font-size: 30rpx;
  color: #4CAF50;
  padding: 10rpx 20rpx;
}

.month-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* 日历 */
.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 10rpx;
}

.week-day {
  font-size: 24rpx;
  color: #999;
  padding: 10rpx 0;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.day-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  margin: 4rpx;
  min-height: 80rpx;
}

.day-cell.empty {
  pointer-events: none;
}

.day-cell.today .day-num {
  color: #4CAF50;
  font-weight: 700;
}

.day-cell.has-task {
  background: #F1F8E9;
}

.day-cell.selected {
  background: #4CAF50;
}

.day-cell.selected .day-num {
  color: #fff;
}

.day-num {
  font-size: 28rpx;
  color: #333;
}

.task-dots {
  display: flex;
  gap: 4rpx;
  margin-top: 6rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #4CAF50;
}

.day-cell.selected .dot {
  background: #fff;
}

/* 日期任务 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 10rpx 16rpx;
}

.day-task-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.day-task-item:last-child {
  border-bottom: none;
}

.day-task-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.day-task-info {
  display: flex;
  flex-direction: column;
}

.day-task-name {
  font-size: 28rpx;
  font-weight: 500;
}

.day-task-type {
  font-size: 24rpx;
  color: #999;
}

.empty-hint {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
