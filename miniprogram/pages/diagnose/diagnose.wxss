/* pages/diagnose/diagnose.wxss */
.input-card { padding: 28rpx; margin-bottom: 16rpx; }
.input-title { font-size: 32rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 16rpx; }
.symptom-input {
  width: 100%; min-height: 120rpx; font-size: 28rpx; color: #2D3436;
  line-height: 1.6; padding: 16rpx; background: #F7F9F7;
  border-radius: 16rpx; border: 2rpx solid #E8F5E9; box-sizing: border-box;
}
.input-actions { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; }
.char-count { font-size: 24rpx; color: #B0BEC5; }
.btn-diagnose {
  background: linear-gradient(135deg, #4CAF50, #66BB6A); color: white;
  padding: 14rpx 40rpx; border-radius: 44rpx; font-size: 28rpx; font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.25);
}
.btn-diagnose.disabled { background: #E0E0E0; color: #9E9E9E; box-shadow: none; }

.quick-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.tag {
  padding: 10rpx 24rpx; background: #F7F9F7; border-radius: 44rpx;
  font-size: 24rpx; color: #607D8B; border: 2rpx solid transparent;
}
.tag.active { background: #E8F5E9; color: #4CAF50; border-color: #4CAF50; }

.section-title { font-size: 32rpx; font-weight: 600; color: #2D3436; margin-bottom: 20rpx; }

.result-card { padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.result-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.result-emoji { font-size: 40rpx; }
.result-title { flex: 1; display: flex; align-items: center; gap: 12rpx; }
.result-name { font-size: 30rpx; font-weight: 600; color: #2D3436; }
.result-severity { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 16rpx; }
.severity-high { background: #E8F5E9; color: #2E7D32; }
.severity-medium { background: #F1F8E9; color: #558B2F; }
.severity-low { background: #E8F5E9; color: #4CAF50; }

.result-cause { font-size: 26rpx; color: #607D8B; margin-bottom: 16rpx; line-height: 1.5; }
.result-cause .label { font-weight: 600; color: #2D3436; }
.result-solutions { margin-bottom: 8rpx; }
.result-solutions .label { font-size: 26rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 8rpx; }
.solution-item { display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 10rpx; }
.sol-num {
  width: 36rpx; height: 36rpx; border-radius: 50%; background: #E8F5E9;
  color: #4CAF50; font-size: 22rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.sol-text { font-size: 26rpx; color: #455A64; line-height: 1.5; }

.no-result { text-align: center; padding: 60rpx; }
.no-result-emoji { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.no-result-text { font-size: 30rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 12rpx; }
.no-result-hint { font-size: 26rpx; color: #90A4AE; }
